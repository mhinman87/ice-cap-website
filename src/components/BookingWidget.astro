---
// BookingWidget.astro - Simple Cal.com embed
const { calLink = "ice-cap-labs-lnw3hf/30min", title = "Book a Call" } = Astro.props;
---

<div class="booking-widget-container">
  <div class="booking-header">
    <h3>{title}</h3>
    <p>Pick a time that works for you</p>
  </div>
  
  <div class="booking-embed-wrapper">
    <iframe 
      src={`https://cal.com/${calLink}?embed=true&theme=dark`}
      width="100%" 
      height="700" 
      frameborder="0"
      style="border-radius: 12px; background: rgba(7, 8, 15, 0.5);"
    ></iframe>
  </div>
</div>

<style>
.booking-widget-container {
  background: var(--bg-deep);
  border: 1px solid rgba(14, 165, 233, 0.2);
  border-radius: 16px;
  padding: 2rem;
  max-width: 900px;
  margin: 0 auto;
}

.booking-header {
  text-align: center;
  margin-bottom: 2rem;
}

.booking-header h3 {
  font-size: 1.75rem;
  color: var(--text-primary);
  margin-bottom: 0.5rem;
  font-weight: 700;
}

.booking-header p {
  color: var(--text-secondary);
  font-size: 1rem;
}

.booking-embed-wrapper {
  border-radius: 12px;
  overflow: hidden;
  background: rgba(7, 8, 15, 0.5);
}

@media (max-width: 768px) {
  .booking-widget-container {
    padding: 1.5rem 1rem;
  }

  .booking-header h3 {
    font-size: 1.5rem;
  }

  .booking-embed-wrapper iframe {
    height: 600px;
  }
}
</style>

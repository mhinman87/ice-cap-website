---
// BookingWidget.astro - Cal.com embed with custom styling
const { calLink = "ice-cap-labs-lnw3hf/30min", title = "Book a Call" } = Astro.props;
---

<div class="booking-widget-container">
  <div class="booking-header">
    <h3>{title}</h3>
    <p>Pick a time that works for you</p>
  </div>
  
  <div class="booking-embed-wrapper">
    <div 
      id="cal-inline-embed"
      data-cal-link={calLink}
      data-cal-config='{"theme":"dark"}'
      style="width:100%;height:700px;overflow:scroll"
    ></div>
  </div>
</div>

<script is:inline>
  (function (C, A, L) { 
    let p = function (a, ar) { a.q.push(ar); }; 
    let d = C.document; 
    C.Cal = C.Cal || function () { 
      let cal = C.Cal; 
      let ar = arguments; 
      if (!cal.loaded) { 
        cal.q = cal.q || []; 
        d.head.appendChild(d.createElement("script")).src = A; 
        cal.loaded = true; 
      } 
      if (ar[0] === L) { 
        const api = function () { p(api, arguments); }; 
        const namespace = ar[1]; 
        api.q = api.q || []; 
        if(typeof namespace === "string"){
          C[namespace] = C[namespace] || api;
          p(C[namespace], ar);
          p(cal, ["initNamespace", namespace]);
        } else p(cal, ar);
        return;
      } 
      p(cal, ar); 
    }; 
  })(window, "https://app.cal.com/embed/embed.js", "init");

  Cal("init", {origin:"https://app.cal.com"});

  Cal("inline", {
    elementOrSelector:"#cal-inline-embed",
    calLink: document.getElementById('cal-inline-embed').getAttribute('data-cal-link'),
    config: JSON.parse(document.getElementById('cal-inline-embed').getAttribute('data-cal-config'))
  });

  Cal("ui", {
    "theme": "dark",
    "styles": {
      "branding": {
        "brandColor": "#0ea5e9"
      }
    },
    "hideEventTypeDetails": false
  });
</script>

<style>
.booking-widget-container {
  background: var(--bg-deep);
  border: 1px solid rgba(14, 165, 233, 0.2);
  border-radius: 16px;
  padding: 2rem;
  max-width: 900px;
  margin: 0 auto;
}

.booking-header {
  text-align: center;
  margin-bottom: 2rem;
}

.booking-header h3 {
  font-size: 1.75rem;
  color: var(--text-primary);
  margin-bottom: 0.5rem;
  font-weight: 700;
}

.booking-header p {
  color: var(--text-secondary);
  font-size: 1rem;
}

.booking-embed-wrapper {
  border-radius: 12px;
  overflow: hidden;
  background: rgba(7, 8, 15, 0.5);
}

/* Cal.com embed customization */
:global(.cal-embed) {
  border-radius: 12px !important;
}

@media (max-width: 768px) {
  .booking-widget-container {
    padding: 1.5rem 1rem;
  }

  .booking-header h3 {
    font-size: 1.5rem;
  }

  .booking-embed-wrapper {
    height: 600px;
  }
}
</style>

---
interface Props {
  dataSpeed?: string;
}
const { dataSpeed } = Astro.props;
---
<footer id="site-footer" data-speed={dataSpeed}>
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="nav-logo footer-logo" aria-label="Ice Cap Labs home">
          <img src="/yeti-transparent.png" alt="Ice Cap Labs" width="30" height="30" />
          <span>Ice Cap Labs</span>
        </a>
        <p class="footer-tagline">Your full-stack technology partner for modern business.</p>
      </div>

      <div class="footer-links">
        <h4>Navigation</h4>
        <ul>
          <li><a href="/products">Products</a></li>
          <li><a href="/process">How It Works</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>

      <div class="footer-contact">
        <h4>Get In Touch</h4>
        <a href="tel:+13166694468" class="footer-phone" style="display: block; margin-bottom: 0.5rem; color: var(--text-primary); text-decoration: none;">(316) 669-4468</a>
        <a href="mailto:hello@icecaplabs.com" class="footer-email">hello@icecaplabs.com</a>
        <div class="footer-socials">
          <!-- X / Twitter -->
          <a href="#" aria-label="Ice Cap Labs on X" class="social-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.259 5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <!-- LinkedIn -->
          <a href="#" aria-label="Ice Cap Labs on LinkedIn" class="social-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
              <rect x="2" y="9" width="4" height="12"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <div class="footer-bar">
      <p>&copy; <span id="footer-year"></span> Ice Cap Labs. All rights reserved.</p>
    </div>
  </div>
</footer>

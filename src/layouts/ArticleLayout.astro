---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  date: string;
  dateFormatted: string;
  topoSvg: string;
}

const { title, description, date, dateFormatted, topoSvg } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Ice Cap Labs</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/png" href="/yeti-transparent.png" />

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-GQN4H5N61M"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-GQN4H5N61M');
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/style.css" />
  <style is:global>
    .article-content mark {
      background: linear-gradient(to right, rgba(14, 165, 233, 0.9) 100%, transparent 0%);
      background-size: 0% 100%;
      background-repeat: no-repeat;
      background-position: left center;
      color: inherit;
      padding: 0.15em 0.35em;
      margin: 0 -0.15em;
      border-radius: 4px;
      transition: background-size 0.7s cubic-bezier(0.22, 1, 0.36, 1),
                  color 0.4s ease 0.2s;
    }
    .article-content mark.highlighted {
      background-size: 100% 100%;
      color: #0a0a0a;
    }
  </style>
</head>
<body>

  <Nav />

  <!-- ARTICLE HERO -->
  <header class="article-hero">
    <div class="article-hero-topo" aria-hidden="true">
      <Fragment set:html={topoSvg} />
    </div>
    <div class="container" style="position:relative; z-index:1;">
      <time class="article-meta" datetime={date}>{dateFormatted}</time>
      <h1 class="article-title word-reveal">{title}</h1>
    </div>
  </header>

  <!-- ARTICLE BODY -->
  <section class="article-body">
    <div class="article-content">
      <slot />
    </div>
  </section>

  <!-- CTA -->
  <section class="page-cta reveal">
    <h2>Ready to Start?</h2>
    <p>Let's talk about what your business needs and build something that moves the needle.</p>
    <a href="/contact" class="btn-primary">Get Started</a>
  </section>

  <Footer />

  <script is:inline src="/script.js"></script>
  <script is:inline>
  (function() {
    var marks = document.querySelectorAll('.article-content mark');
    if (!marks.length) return;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('highlighted');
          observer.unobserve(entry.target);
        }
      });
    }, { rootMargin: '0px 0px -33% 0px', threshold: 0.5 });
    marks.forEach(function(mark) { observer.observe(mark); });
  })();
  </script>
</body>
</html>

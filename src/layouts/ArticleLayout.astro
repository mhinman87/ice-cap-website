---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  date: string;
  dateFormatted: string;
  topoSvg: string;
}

const { title, description, date, dateFormatted, topoSvg } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Ice Cap Labs</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/png" href="/yeti-transparent.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/style.css" />
</head>
<body>

  <Nav />

  <!-- ARTICLE HERO -->
  <header class="article-hero">
    <div class="article-hero-topo" aria-hidden="true">
      <Fragment set:html={topoSvg} />
    </div>
    <div class="container" style="position:relative; z-index:1;">
      <a href="/blog" class="article-back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        Back to Blog
      </a>
      <time class="article-meta" datetime={date}>{dateFormatted}</time>
      <h1 class="article-title word-reveal">{title}</h1>
    </div>
  </header>

  <!-- ARTICLE BODY -->
  <section class="article-body">
    <div class="article-content">
      <slot />
    </div>
  </section>

  <!-- CTA -->
  <section class="page-cta reveal">
    <h2>Ready to Start?</h2>
    <p>Let's talk about what your business needs and build something that moves the needle.</p>
    <a href="/contact" class="btn-primary">Get Started</a>
  </section>

  <Footer />

  <script is:inline src="/script.js"></script>
</body>
</html>

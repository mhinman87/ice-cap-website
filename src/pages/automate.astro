---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCard from '../components/ContactCard.astro';
---
<BaseLayout title="AI Automation | Ice Cap Labs | Wichita, KS" description="AI automation services for Wichita, Kansas businesses — workflow optimization, chatbots, document processing, reporting, and custom AI tools.">

  <!-- PIXEL HERO -->
  <section class="pixel-hero">
    <h1 class="pixel-hero-title" aria-label="Automate">AUTOMATE</h1>
    <div class="pixel-title-grid" id="pixel-title-grid"></div>
  </section>

  <!-- CHOOSE YOUR PATH -->
  <section class="chooser" id="chooser">
    <div class="chooser-buttons" id="chooser-buttons">
      <button class="chooser-btn" id="btn-need" data-choice="need">
        <span class="chooser-btn-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
          </svg>
        </span>
        <span class="chooser-btn-label">I Need AI Automation</span>
      </button>
      <button class="chooser-btn" id="btn-what" data-choice="what">
        <span class="chooser-btn-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
            <line x1="12" y1="17" x2="12.01" y2="17"/>
          </svg>
        </span>
        <span class="chooser-btn-label">What is AI Automation?</span>
      </button>
    </div>
    <div class="chooser-line" id="chooser-line" aria-hidden="true"></div>
  </section>

  <!-- CONTACT CARD -->
  <section id="contact" style="background: var(--bg-deep); padding: 6rem 0;">
    <div class="container">
      <ContactCard />
    </div>
  </section>

  <style is:global>
    .chooser {
      background: var(--bg-void);
      padding: 6rem 0 8rem;
      min-height: 60vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      overflow: hidden;
    }

    .chooser-buttons {
      display: flex;
      gap: 2rem;
      justify-content: center;
      width: 100%;
      max-width: 900px;
      padding: 0 clamp(1rem, 4vw, 2rem);
    }

    .chooser-btn {
      flex: 1;
      max-width: 400px;
      padding: 2.5rem 2rem;
      background: var(--accent);
      border: 1px solid rgba(56, 189, 248, 0.4);
      border-radius: 10px;
      cursor: pointer;
      color: #fff;
      font-family: 'Outfit', sans-serif;
      font-size: 1.35rem;
      font-weight: 600;
      letter-spacing: 0.02em;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      transition:
        transform 2s cubic-bezier(0.16, 1, 0.3, 1),
        opacity 1.6s cubic-bezier(0.16, 1, 0.3, 1),
        border-color 0.3s ease,
        box-shadow 0.3s ease;
      box-shadow: 0 4px 20px rgba(14,165,233,0.3);
    }

    .chooser-btn:hover {
      border-color: var(--accent-bright);
      box-shadow:
        0 0 40px rgba(14,165,233,0.4),
        inset 0 0 30px rgba(255,255,255,0.05);
      transform: translateY(-4px);
    }

    .chooser-btn:active {
      transform: translateY(-1px);
    }

    .chooser-btn-icon {
      color: #fff;
    }

    .chooser-btn.dismissed {
      opacity: 0;
      pointer-events: none;
    }

    .chooser-btn.chosen {
      pointer-events: none;
      border-color: var(--accent);
      box-shadow: 0 0 40px rgba(14,165,233,0.3);
    }

    .chooser-line {
      width: 2px;
      height: 0;
      background: var(--accent);
      box-shadow: 0 0 12px rgba(14,165,233,0.6), 0 0 4px rgba(14,165,233,0.8);
      transition: height 3s linear;
      position: relative;
    }

    .chooser-line::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 50%;
      transform: translateX(-50%);
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--accent-bright);
      box-shadow: 0 0 16px var(--accent), 0 0 6px var(--accent-bright);
      opacity: 0;
      transition: opacity 0.5s ease 1.8s;
    }

    .chooser-line.extending {
      height: 200px;
    }

    .chooser-line.extending::after {
      opacity: 1;
    }

    @media (max-width: 640px) {
      .chooser-buttons {
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
      }

      .chooser-btn {
        max-width: 100%;
        width: 100%;
        padding: 2rem 1.5rem;
        font-size: 1.15rem;
      }

      .chooser-btn.dismissed {
        transform: scale(0.9) !important;
      }
    }
  </style>

  <script is:inline>
  (function() {
    var container = document.getElementById('chooser-buttons');
    var line = document.getElementById('chooser-line');
    if (!container || !line) return;

    var btnNeed = document.getElementById('btn-need');
    var btnWhat = document.getElementById('btn-what');
    var chosen = false;

    function handleChoice(chosenBtn, dismissedBtn) {
      if (chosen) return;
      chosen = true;

      var containerRect = container.getBoundingClientRect();
      var chosenRect = chosenBtn.getBoundingClientRect();
      var dismissedRect = dismissedBtn.getBoundingClientRect();

      var containerCenterX = containerRect.left + containerRect.width / 2;
      var chosenCenterX = chosenRect.left + chosenRect.width / 2;
      var offsetX = containerCenterX - chosenCenterX;

      var dismissDirection = dismissedRect.left < chosenRect.left ? -1 : 1;
      var dismissX = dismissDirection * containerRect.width;

      dismissedBtn.style.transform = 'translateX(' + dismissX + 'px)';
      dismissedBtn.classList.add('dismissed');

      chosenBtn.style.transform = 'translateX(' + offsetX + 'px)';
      chosenBtn.classList.add('chosen');

      setTimeout(function() {
        line.classList.add('extending');
      }, 800);
    }

    btnNeed.addEventListener('click', function() { handleChoice(btnNeed, btnWhat); });
    btnWhat.addEventListener('click', function() { handleChoice(btnWhat, btnNeed); });
  })();
  </script>

</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="AI Automation | Ice Cap Labs | Wichita, KS" description="AI automation services for Wichita, Kansas businesses — workflow optimization, chatbots, document processing, reporting, and custom AI tools.">

  <!-- PIXEL HERO -->
  <section class="pixel-hero">
    <h1 class="pixel-hero-title" aria-label="Automate">AUTOMATE</h1>
    <div class="pixel-title-grid" id="pixel-title-grid"></div>
  </section>

  <!-- TIME AS ROI -->
  <section class="blocks-section" style="background: var(--bg-deep);">
    <div class="blocks-container">
      <div class="service-block reveal">
        <div class="block-inner">
          <div>
            <p class="block-number">The Real ROI</p>
            <h2 class="block-title">Time Is Your Only Non-Renewable Resource</h2>
          </div>
          <div>
            <p class="block-desc">
              Money compounds. Skills improve. Reputation builds over time. But hours? Once they're spent on repetitive work, they're gone forever. <mark>The real ROI of automation isn't just cost savings. It's reclaiming time you'll never get back.</mark>
            </p>
            <p class="block-desc">
              We build AI systems that eliminate the work your team shouldn't be doing manually. Not experimental demos. Not chatbots that frustrate customers. Practical, reliable automation that saves measurable time every single week.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- AUTOMATION SPECTRUM -->
  <section class="blocks-section" style="background: var(--bg-void);">
    <div class="blocks-container">
      <div class="service-block reveal">
        <div class="block-inner">
          <div>
            <p class="block-number">Simple → Advanced</p>
            <h2 class="block-title">Automation That Grows With You</h2>
          </div>
          <div>
            <p class="block-desc">
              Not every business needs AI employees on day one. We meet you where you are and build systems that scale from simple workflows to full operational automation.
            </p>
          </div>
        </div>
      </div>

      <!-- SIMPLE -->
      <div class="service-block reveal" data-delay="0.1">
        <div class="block-inner">
          <div>
            <h3 class="block-title" style="font-size: 1.5rem;">Simple Automation</h3>
            <p style="color: var(--text-secondary); font-size: 0.9rem; margin-top: 0.5rem;">Save 5-10 hours/week</p>
          </div>
          <div>
            <ul class="block-list">
              <li><strong>Email filtering and auto-responses</strong> — Route inquiries to the right person, send instant confirmations</li>
              <li><strong>Appointment scheduling</strong> — Sync calendars, send reminders, handle rescheduling</li>
              <li><strong>Data entry automation</strong> — Pull data from forms/emails into your CRM or spreadsheets</li>
              <li><strong>Social media scheduling</strong> — Queue posts, optimize timing, cross-post to multiple platforms</li>
              <li><strong>Document organization</strong> — Auto-file invoices, contracts, receipts by date/client/type</li>
            </ul>
            <p class="block-desc" style="margin-top: 1rem;">
              <strong>Example:</strong> A local contractor was spending 6 hours/week responding to quote requests via email. We built an automation that reads the request, pulls pricing from their database, generates a PDF quote, and emails it back. Response time went from 24 hours to 10 minutes.
            </p>
          </div>
        </div>
      </div>

      <!-- MEDIUM -->
      <div class="service-block reveal" data-delay="0.2">
        <div class="block-inner">
          <div>
            <h3 class="block-title" style="font-size: 1.5rem;">Multi-Step Workflows</h3>
            <p style="color: var(--text-secondary); font-size: 0.9rem; margin-top: 0.5rem;">Save 10-20 hours/week</p>
          </div>
          <div>
            <ul class="block-list">
              <li><strong>Lead qualification pipelines</strong> — Score leads, route to sales, trigger follow-up sequences</li>
              <li><strong>Customer onboarding</strong> — Send welcome emails, provision accounts, schedule kickoff calls</li>
              <li><strong>Invoice-to-payment workflows</strong> — Generate invoices, send reminders, reconcile payments, update accounting</li>
              <li><strong>Inventory management</strong> — Track stock levels, trigger reorders, sync across sales channels</li>
              <li><strong>Project status reporting</strong> — Pull data from multiple tools, generate weekly reports, distribute to stakeholders</li>
            </ul>
            <p class="block-desc" style="margin-top: 1rem;">
              <strong>Example:</strong> A retail shop was manually syncing inventory between their POS, website, and accounting software every morning (2 hours/day). We built a workflow that syncs in real-time and flags discrepancies for review. Time savings: 10 hours/week.
            </p>
          </div>
        </div>
      </div>

      <!-- ADVANCED -->
      <div class="service-block reveal" data-delay="0.3">
        <div class="block-inner">
          <div>
            <h3 class="block-title" style="font-size: 1.5rem;">AI Employees</h3>
            <p style="color: var(--text-secondary); font-size: 0.9rem; margin-top: 0.5rem;">Save 20-40+ hours/week</p>
          </div>
          <div>
            <p class="block-desc">
              This is where it gets interesting. <mark>AI agents that don't just automate tasks — they make decisions, adapt to context, and operate across your entire tech stack.</mark>
            </p>
            <ul class="block-list">
              <li><strong>Autonomous customer support</strong> — Handle common questions, escalate complex issues, learn from interactions</li>
              <li><strong>Business intelligence agents</strong> — Monitor KPIs, identify trends, flag anomalies, generate insights</li>
              <li><strong>Social media managers</strong> — Draft posts, schedule strategically, respond to comments, track engagement</li>
              <li><strong>Project coordinators</strong> — Update task boards, send status updates, coordinate team schedules</li>
              <li><strong>Research assistants</strong> — Gather competitive intel, summarize industry news, prep for meetings</li>
            </ul>
            <p class="block-desc" style="margin-top: 1rem;">
              <strong>Example:</strong> I run three businesses using AI agents built on <a href="/blog/five-weeks-with-openclaw" style="color: var(--accent); text-decoration: underline;">OpenClaw</a>. They handle social media, inventory tracking, morning briefs, and coordination across teams. They don't replace me — they handle everything I was doing manually that didn't require my judgment.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- OPENCLAW SHOWCASE -->
  <section class="blocks-section" style="background: var(--bg-deep);">
    <div class="blocks-container">
      <div class="service-block reveal">
        <div class="block-inner">
          <div>
            <p class="block-number">How I Run My Business</p>
            <h2 class="block-title">OpenClaw: AI Agents That Actually Work</h2>
          </div>
          <div>
            <p class="block-desc">
              Most AI tools live in a chatbot window. You ask questions, they answer, nothing actually happens. <mark>OpenClaw is different. It's AI agents with real access to your tools — email, CRM, databases, calendars, social media.</mark>
            </p>
            <p class="block-desc">
              I've been using it for five weeks to run Ice Cap Labs and two other businesses. My agents post to social media, track inventory, send morning briefs, coordinate meetings, and handle workflows that used to eat 15-20 hours of my week.
            </p>
            <p class="block-desc">
              This isn't experimental. It's how I operate every day. And if you're running a small business and not exploring this technology yet, you're about to fall behind.
            </p>
            <a href="/blog/five-weeks-with-openclaw" class="btn-primary" style="margin-top: 1.5rem;">Read My Full OpenClaw Story</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ROI CALCULATOR -->
  <section class="blocks-section" style="background: var(--bg-void);">
    <div class="blocks-container">
      <div class="service-block reveal">
        <div class="block-inner">
          <div>
            <p class="block-number">Calculate Your Savings</p>
            <h2 class="block-title">What Could You Get Back?</h2>
          </div>
          <div>
            <p class="block-desc">
              Quick estimate: How much time could automation save your team?
            </p>
            
            <div style="background: var(--bg-deep); padding: 2rem; border-radius: 8px; margin-top: 2rem;">
              <div style="display: grid; gap: 1.5rem;">
                <div>
                  <label for="hours-week" style="display: block; margin-bottom: 0.5rem; color: var(--text-primary);">Hours/week spent on repetitive tasks:</label>
                  <input type="number" id="hours-week" min="1" max="168" value="10" 
                    style="width: 100%; padding: 0.75rem; background: var(--bg-void); border: 1px solid rgba(139,92,246,0.3); border-radius: 4px; color: var(--text-primary); font-size: 1rem;" />
                </div>
                
                <div>
                  <label for="hourly-rate" style="display: block; margin-bottom: 0.5rem; color: var(--text-primary);">Average hourly cost (salary + overhead):</label>
                  <input type="number" id="hourly-rate" min="10" max="500" value="50" 
                    style="width: 100%; padding: 0.75rem; background: var(--bg-void); border: 1px solid rgba(139,92,246,0.3); border-radius: 4px; color: var(--text-primary); font-size: 1rem;" />
                </div>
                
                <div>
                  <label for="automation-percentage" style="display: block; margin-bottom: 0.5rem; color: var(--text-primary);">Automation potential (%):</label>
                  <input type="range" id="automation-percentage" min="30" max="90" value="60" 
                    style="width: 100%;" />
                  <span id="automation-display" style="color: var(--accent); font-weight: 600;">60%</span>
                </div>
              </div>

              <div style="margin-top: 2rem; padding: 1.5rem; background: rgba(139,92,246,0.1); border-left: 3px solid var(--accent); border-radius: 4px;">
                <p style="font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 0.5rem;">Annual Time Savings:</p>
                <p id="time-saved" style="font-size: 2rem; font-weight: 700; color: var(--accent); margin-bottom: 1rem;">312 hours/year</p>
                
                <p style="font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 0.5rem;">Annual Cost Savings:</p>
                <p id="cost-saved" style="font-size: 2rem; font-weight: 700; color: var(--accent);">$15,600/year</p>
              </div>

              <p style="margin-top: 1.5rem; font-size: 0.9rem; color: var(--text-secondary);">
                <em>These are conservative estimates. Many businesses see 70-80% automation of repetitive workflows.</em>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="blocks-section" style="background: var(--bg-deep);">
    <div class="blocks-container">
      <div class="service-block reveal">
        <div class="block-inner">
          <div>
            <p class="block-number">Common Questions</p>
            <h2 class="block-title">What You're Probably Wondering</h2>
          </div>
          <div>
            <div style="display: grid; gap: 2rem;">
              <div>
                <h3 style="font-size: 1.25rem; margin-bottom: 0.75rem; color: var(--text-primary);">How long does automation take to set up?</h3>
                <p style="color: var(--text-secondary); line-height: 1.7;">Simple automations (email filters, scheduling): 1-2 days. Multi-step workflows: 1-2 weeks. AI employees: 2-4 weeks depending on complexity. You'll see time savings from week one.</p>
              </div>

              <div>
                <h3 style="font-size: 1.25rem; margin-bottom: 0.75rem; color: var(--text-primary);">What if something breaks?</h3>
                <p style="color: var(--text-secondary); line-height: 1.7;">Good automation fails gracefully. If an AI agent encounters something it can't handle, it escalates to a human instead of breaking silently. We build monitoring and alerts into every system so you know immediately if something needs attention.</p>
              </div>

              <div>
                <h3 style="font-size: 1.25rem; margin-bottom: 0.75rem; color: var(--text-primary);">Will this replace my team?</h3>
                <p style="color: var(--text-secondary); line-height: 1.7;">No. Automation handles the repetitive 60% so your team can focus on the strategic 40%. Your people become more valuable, not less, because they're doing work that actually requires human judgment instead of data entry.</p>
              </div>

              <div>
                <h3 style="font-size: 1.25rem; margin-bottom: 0.75rem; color: var(--text-primary);">What tools do you integrate with?</h3>
                <p style="color: var(--text-secondary); line-height: 1.7;">Most common business tools: Gmail, Google Workspace, Slack, QuickBooks, Shopify, WordPress, HubSpot, Salesforce, Monday.com, Asana, and dozens more. If it has an API or integration capability, we can connect to it.</p>
              </div>

              <div>
                <h3 style="font-size: 1.25rem; margin-bottom: 0.75rem; color: var(--text-primary);">How much does this cost?</h3>
                <p style="color: var(--text-secondary); line-height: 1.7;">Simple automations start around $1,500. Multi-step workflows: $3,000-$8,000. AI employee implementations: $8,000-$20,000 depending on scope. Most businesses see positive ROI within 60-90 days.</p>
              </div>

              <div>
                <h3 style="font-size: 1.25rem; margin-bottom: 0.75rem; color: var(--text-primary);">Do I need technical expertise?</h3>
                <p style="color: var(--text-secondary); line-height: 1.7;">Nope. We handle the technical implementation. You just need to be able to describe the workflow you want automated. We translate that into working systems and train your team on how to use them.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="page-cta reveal">
    <h2>Ready to Reclaim Your Time?</h2>
    <p>Let's talk about what you're currently doing manually that could be automated.</p>
    <a href="/contact" class="btn-primary">Start the Conversation</a>
  </section>

  <script>
    // ROI Calculator
    const hoursInput = document.getElementById('hours-week');
    const rateInput = document.getElementById('hourly-rate');
    const percentInput = document.getElementById('automation-percentage');
    const percentDisplay = document.getElementById('automation-display');
    const timeSavedDisplay = document.getElementById('time-saved');
    const costSavedDisplay = document.getElementById('cost-saved');

    function calculate() {
      const hours = parseFloat(hoursInput.value) || 0;
      const rate = parseFloat(rateInput.value) || 0;
      const percent = parseFloat(percentInput.value) || 0;

      const weeklySaved = hours * (percent / 100);
      const annualHoursSaved = Math.round(weeklySaved * 52);
      const annualCostSaved = Math.round(annualHoursSaved * rate);

      timeSavedDisplay.textContent = `${annualHoursSaved.toLocaleString()} hours/year`;
      costSavedDisplay.textContent = `$${annualCostSaved.toLocaleString()}/year`;
      percentDisplay.textContent = `${percent}%`;
    }

    hoursInput.addEventListener('input', calculate);
    rateInput.addEventListener('input', calculate);
    percentInput.addEventListener('input', calculate);

    // Initialize
    calculate();
  </script>

</BaseLayout>

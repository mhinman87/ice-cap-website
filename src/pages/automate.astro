---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="AI Automation | Ice Cap Labs | Wichita, KS" description="AI automation services for Wichita, Kansas businesses — workflow optimization, chatbots, document processing, reporting, and custom AI tools.">

  <!-- PIXEL HERO -->
  <section class="pixel-hero">
    <h1 class="pixel-hero-title" aria-label="Automate">AUTOMATE</h1>
    <div class="pixel-title-grid" id="pixel-title-grid"></div>
  </section>

  <!-- SERVICE DETAILS -->
  <section class="blocks-section" style="background: var(--bg-deep);">
    <div class="blocks-container">
      <div class="service-block reveal">
        <div class="block-inner">
          <div>
            <p class="block-number">AI Automation</p>
            <h2 class="block-title">Automation That Delivers Today</h2>
          </div>
          <div>
            <p class="block-desc">
              Practical, reliable AI integrations that eliminate repetitive work and free up your team's time. We focus on automations that deliver measurable results today — not experimental demos that sound impressive but go nowhere.
            </p>
            <ul class="block-list">
              <li>Workflow automation and process optimization</li>
              <li>AI-powered customer support and chatbots</li>
              <li>Document processing and data extraction</li>
              <li>Automated reporting and business intelligence</li>
              <li>CRM and sales pipeline automation</li>
              <li>Custom AI tool development for your specific use case</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="page-cta reveal">
    <h2>Ready to Automate?</h2>
    <p>Let's talk about eliminating the work your team shouldn't be doing manually.</p>
    <a href="/contact" class="btn-primary">Get Started</a>
  </section>

</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "How Wichita Service Businesses Lose $50K+ Annually to Missed Calls (And How to Fix It)";
const description = "Local HVAC, plumbing, and electrical companies in Wichita are losing thousands in revenue to missed calls. Here's the math—and the solution.";
const publishDate = "2026-03-24";
const author = "Max Brody";
const slug = "wichita-service-businesses-losing-money-missed-calls";
---

<BaseLayout title={title} description={description}>
  <article class="blog-post" itemscope itemtype="https://schema.org/Article">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": title,
      "description": description,
      "author": {
        "@type": "Person",
        "name": author
      },
      "publisher": {
        "@type": "Organization",
        "name": "Ice Cap Labs",
        "logo": {
          "@type": "ImageObject",
          "url": "https://icecaplabs.com/yeti-icon.png"
        }
      },
      "datePublished": publishDate,
      "dateModified": publishDate,
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": `https://icecaplabs.com/blog/${slug}`
      },
      "keywords": "Wichita service businesses, missed calls, HVAC Wichita, plumbing business, electrical contractors, AI call assistant, business automation, revenue loss, customer service, after hours calls",
      "articleSection": "Business Growth",
      "wordCount": 2400

---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCard from '../components/ContactCard.astro';
---
<BaseLayout title="24/7 Call & Text Assistant | Ice Cap Labs | Wichita, KS" description="AI-powered call and text assistant for Wichita, Kansas businesses — after-hours answering, lead qualification, appointment booking, and emergency triage.">

  <!-- PIXEL HERO -->
  <section class="pixel-hero">
    <h1 class="pixel-hero-title" aria-label="Call Assistant">CALL ASSISTANT</h1>
    <div class="pixel-title-grid" id="pixel-title-grid"></div>
  </section>

  <!-- CHOOSE YOUR PATH -->
  <section class="chooser" id="chooser">
    <div class="chooser-buttons" id="chooser-buttons">
      <button class="chooser-btn" id="btn-need" data-choice="need">
        <span class="chooser-btn-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <circle cx="12" cy="12" r="6"/>
            <circle cx="12" cy="12" r="2"/>
          </svg>
        </span>
        <span class="chooser-btn-label">I Need a Call Assistant</span>
      </button>
      <button class="chooser-btn" id="btn-what" data-choice="what">
        <span class="chooser-btn-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
            <line x1="12" y1="17" x2="12.01" y2="17"/>
          </svg>
        </span>
        <span class="chooser-btn-label">What Is a Call Assistant?</span>
      </button>
    </div>
    <div class="chooser-line" id="chooser-line" aria-hidden="true"></div>
    <div id="flow-container" class="flow-container" aria-live="polite"></div>
  </section>

  <!-- CONTACT CARD -->
  <section id="contact" class="flow-contact-hidden" style="background: var(--bg-deep); padding: 6rem 0;">
    <div class="container">
      <ContactCard />
    </div>
  </section>

  <style is:global>
    /* ── Chooser ──────────────────────────────────────────── */
    .chooser {
      background: var(--bg-void);
      padding: 6rem 0 4rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      overflow: visible;
    }

    .chooser-buttons {
      display: flex;
      gap: 2rem;
      justify-content: center;
      width: 100%;
      max-width: 900px;
      padding: 0 clamp(1rem, 4vw, 2rem);
    }

    .chooser-btn {
      flex: 1;
      max-width: 400px;
      padding: 2.5rem 2rem;
      background: var(--accent);
      border: 1px solid rgba(56, 189, 248, 0.4);
      border-radius: 10px;
      cursor: pointer;
      color: #fff;
      font-family: 'Outfit', sans-serif;
      font-size: 1.35rem;
      font-weight: 600;
      letter-spacing: 0.02em;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      transition:
        transform 2s cubic-bezier(0.16, 1, 0.3, 1),
        opacity 1.6s cubic-bezier(0.16, 1, 0.3, 1),
        border-color 0.3s ease,
        box-shadow 0.3s ease;
      box-shadow: 0 4px 20px rgba(14,165,233,0.3);
    }

    .chooser-btn:hover {
      border-color: var(--accent-bright);
      box-shadow:
        0 0 40px rgba(14,165,233,0.4),
        inset 0 0 30px rgba(255,255,255,0.05);
      transform: translateY(-4px);
    }

    .chooser-btn:active {
      transform: translateY(-1px);
    }

    .chooser-btn-icon {
      color: #fff;
    }

    .chooser-btn.dismissed {
      opacity: 0;
      pointer-events: none;
    }

    .chooser-btn.chosen {
      pointer-events: none;
      border-color: var(--accent);
      box-shadow: 0 0 40px rgba(14,165,233,0.3);
    }

    .chooser-line {
      width: 2px;
      height: 0;
      background: var(--accent);
      box-shadow: 0 0 12px rgba(14,165,233,0.6), 0 0 4px rgba(14,165,233,0.8);
      transition: height 3s linear;
      position: relative;
      align-self: center;
    }

    .chooser-line::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 50%;
      transform: translateX(-50%);
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--accent-bright);
      box-shadow: 0 0 16px var(--accent), 0 0 6px var(--accent-bright);
      opacity: 0;
      transition: opacity 0.5s ease 1.8s;
    }

    .chooser-line.extending {
      height: 200px;
    }

    .chooser-line.extending::after {
      opacity: 1;
    }

    .chooser-line.hide-line {
      display: none;
    }

    @media (max-width: 640px) {
      .chooser-buttons {
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
      }

      .chooser-btn {
        max-width: 100%;
        width: 100%;
        padding: 2rem 1.5rem;
        font-size: 1.15rem;
      }

      .chooser-btn.dismissed {
        transform: scale(0.9) !important;
      }
    }

    /* ── Flow Container ──────────────────────────────────── */
    .flow-container {
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 100%;
      max-width: 900px;
      margin: 0 auto;
      padding: 0 clamp(1rem, 4vw, 2rem);
    }

    .flow-node {
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 100%;
      margin: 0;
      padding: 0;
    }

    /* ── Flow Line Segments ──────────────────────────────── */
    .flow-line {
      width: 2px;
      height: 0;
      background: var(--accent);
      box-shadow: 0 0 12px rgba(14,165,233,0.6), 0 0 4px rgba(14,165,233,0.8);
      transition: height 2s linear;
      position: relative;
    }

    .flow-line::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 50%;
      transform: translateX(-50%);
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--accent-bright);
      box-shadow: 0 0 16px var(--accent), 0 0 6px var(--accent-bright);
      opacity: 0;
      transition: opacity 0.4s ease 1.6s;
    }

    .flow-line.extending {
      height: 120px;
    }

    .flow-line.extending::after {
      opacity: 1;
    }

    .flow-line.arrow::after {
      width: 0;
      height: 0;
      background: none;
      border-radius: 0;
      box-shadow: none;
      border-left: 8px solid transparent;
      border-right: 8px solid transparent;
      border-top: 12px solid var(--accent-bright);
      bottom: -12px;
      filter: drop-shadow(0 0 8px var(--accent)) drop-shadow(0 0 4px var(--accent-bright));
    }

    /* ── Flow Cards ──────────────────────────────────────── */
    .flow-card {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                  transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
      text-align: center;
      width: 100%;
      max-width: 700px;
      padding: 1rem 0 0;
    }

    .flow-card.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .flow-card-title {
      font-size: clamp(1.2rem, 3vw, 1.6rem);
      color: var(--text-primary);
      margin-bottom: 1.5rem;
      font-weight: 600;
    }

    .flow-card-text {
      font-size: 1.1rem;
      color: white;
      line-height: 1.75;
      margin-bottom: 1.5rem;
      max-width: 560px;
      margin-left: auto;
      margin-right: auto;
    }

    /* ── Flow Options (answer buttons) ───────────────────── */
    .flow-card-options {
      display: flex;
      flex-wrap: nowrap;
      gap: 0.5rem;
      justify-content: center;
    }

    .flow-option {
      -webkit-appearance: none;
      appearance: none;
      padding: 0.75rem 1rem;
      background: var(--accent) !important;
      white-space: nowrap;
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 10px;
      color: #fff;
      font-family: 'Outfit', sans-serif;
      font-size: 0.95rem;
      font-weight: 500;
      cursor: pointer;
      transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                  opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                  border-color 0.3s ease,
                  box-shadow 0.3s ease;
    }

    .flow-option:hover {
      border-color: var(--accent-bright);
      box-shadow: 0 0 20px rgba(14,165,233,0.3);
      transform: translateY(-2px);
    }

    .flow-option.chosen {
      border-color: var(--accent);
      background: var(--accent);
      box-shadow: 0 0 30px rgba(14,165,233,0.3);
      pointer-events: none;
      transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .flow-option.dismissed {
      opacity: 0;
      pointer-events: none;
      transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1),
                  opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .flow-option.dismissed-left {
      transform: translateX(-200vw);
    }

    .flow-option.dismissed-right {
      transform: translateX(200vw);
    }

    /* ── Continue Button ─────────────────────────────────── */
    .flow-continue {
      display: inline-block;
      padding: 0.875rem 2rem;
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: 10px;
      font-family: 'Outfit', sans-serif;
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      box-shadow: 0 4px 20px rgba(14,165,233,0.4);
      transition: transform 0.2s, box-shadow 0.2s;
      margin-top: 1rem;
    }

    .flow-continue:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 30px rgba(14,165,233,0.55);
    }

    /* ── Examples Grid ───────────────────────────────────── */
    .flow-examples {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
      margin-bottom: 1.5rem;
      width: 100%;
    }

    .flow-example {
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 12px;
      padding: 1.5rem 1rem;
      text-align: center;
    }

    .flow-example-icon {
      width: 44px;
      height: 44px;
      background: rgba(14, 165, 233, 0.15);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 0.75rem;
      color: var(--accent-bright);
    }

    .flow-example h4 {
      font-size: 0.95rem;
      color: var(--text-primary);
      margin-bottom: 0.4rem;
      font-weight: 600;
    }

    .flow-example p {
      font-size: 0.85rem;
      color: var(--text-secondary);
      line-height: 1.6;
    }

    /* ── Tiers Grid ──────────────────────────────────────── */
    .flow-tiers {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
      margin-bottom: 1.5rem;
      width: 100%;
    }

    .flow-tier {
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 12px;
      padding: 2rem 1.25rem;
      text-align: center;
      transition: border-color 0.3s, box-shadow 0.3s;
    }

    .flow-tier.recommended {
      border-color: var(--accent);
      box-shadow: 0 0 30px rgba(14,165,233,0.2);
    }

    .flow-tier-label {
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent-bright);
      margin-bottom: 0.75rem;
    }

    .flow-tier h4 {
      font-size: 1.05rem;
      color: var(--text-primary);
      margin-bottom: 0.5rem;
      font-weight: 600;
    }

    .flow-tier-price {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--accent-bright);
      margin-bottom: 0.75rem;
    }

    .flow-tier-saves {
      font-size: 0.8rem;
      color: var(--accent);
      font-weight: 600;
      margin-bottom: 0.5rem;
    }

    .flow-tier p {
      font-size: 0.85rem;
      color: var(--text-secondary);
      line-height: 1.6;
    }

    /* ── Result Card ─────────────────────────────────────── */
    .flow-result {
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid var(--accent);
      border-radius: 16px;
      padding: 2.5rem 2rem;
      text-align: center;
      box-shadow: 0 0 40px rgba(14,165,233,0.2);
      max-width: 480px;
      margin: 0 auto;
    }

    .flow-result-eyebrow {
      font-size: 0.7rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent-bright);
      margin-bottom: 0.75rem;
    }

    .flow-result h3 {
      font-size: 1.4rem;
      color: var(--text-primary);
      margin-bottom: 0.5rem;
      font-weight: 700;
    }

    .flow-result-price {
      font-size: 2rem;
      font-weight: 700;
      color: var(--accent-bright);
      margin-bottom: 1rem;
    }

    .flow-result p {
      font-size: 0.95rem;
      color: var(--text-secondary);
      line-height: 1.7;
      margin-bottom: 1.5rem;
    }

    /* ── Contact Reveal ──────────────────────────────────── */
    .flow-contact-hidden {
      display: none;
    }

    .flow-contact-reveal {
      display: block;
      opacity: 0;
      transform: translateY(40px);
      transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                  transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .flow-contact-visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* ── Responsive ──────────────────────────────────────── */
    @media (max-width: 640px) {
      .flow-examples {
        grid-template-columns: 1fr;
      }

      .flow-tiers {
        grid-template-columns: 1fr;
      }

      .flow-option.dismissed {
        transform: scale(0.85) !important;
      }

      .flow-card-options {
        flex-wrap: wrap;
      }
    }
  </style>

  <script is:inline>
  (function() {
    var container = document.getElementById('chooser-buttons');
    var chooserLine = document.getElementById('chooser-line');
    var flowContainer = document.getElementById('flow-container');
    var contactSection = document.getElementById('contact');
    if (!container || !chooserLine || !flowContainer) return;

    var btnNeed = document.getElementById('btn-need');
    var btnWhat = document.getElementById('btn-what');
    var chosen = false;
    var answers = {};
    var currentPath = null;
    var currentStepIndex = 0;
    var currentRec = null;

    /* ── Step Definitions ───────────────────────────────── */

    var NEED_STEPS = [
      {
        id: 'need-1',
        type: 'question',
        title: 'What do you need your call assistant to handle?',
        key: 'scope',
        options: [
          { value: 'afterhours', label: 'After-Hours Calls' },
          { value: 'leads', label: 'Lead Qualification' },
          { value: 'booking', label: 'Appointment Booking' },
          { value: 'all', label: 'All of the Above' }
        ]
      },
      {
        id: 'need-2',
        type: 'question',
        title: 'How many calls does your business get per day?',
        key: 'volume',
        options: [
          { value: 'low', label: 'Under 10' },
          { value: 'medium', label: '10\u201350' },
          { value: 'high', label: '50+' }
        ]
      },
      {
        id: 'need-3',
        type: 'question',
        title: "What\u2019s your budget range?",
        key: 'budget',
        options: [
          { value: 'low', label: 'Under $2k' },
          { value: 'mid', label: '$2\u20135k' },
          { value: 'high', label: '$5k+' }
        ]
      }
    ];

    var WHAT_STEPS = [
      {
        id: 'what-1',
        type: 'info',
        text: "An AI call assistant answers your phone 24/7 \u2014 after hours, weekends, holidays. It qualifies leads, books appointments, triages emergencies, and sends you a summary. Your customers never hit voicemail again.",
        continueLabel: 'Show Me Examples'
      },
      {
        id: 'what-2',
        type: 'examples',
        title: "Here\u2019s what your call assistant handles:",
        examples: [
          {
            icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>',
            title: 'After-Hours Answering',
            desc: 'Never miss a call again \u2014 AI picks up when you can\u2019t and handles it like your best employee.'
          },
          {
            icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
            title: 'Lead Qualification',
            desc: 'Asks the right questions, scores the lead, and routes hot prospects straight to your phone.'
          },
          {
            icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>',
            title: 'Appointment Booking',
            desc: 'Books directly into your calendar \u2014 confirms with the customer and sends you a notification.'
          }
        ],
        continueLabel: 'What Does It Cost?'
      },
      {
        id: 'what-3',
        type: 'tiers',
        title: 'Three levels of coverage:'
      }
    ];

    /* ── Recommendation Logic ───────────────────────────── */

    function getRecommendation() {
      if (answers.budget === 'high') {
        return {
          label: 'FULL AI RECEPTIONIST',
          name: 'Full AI Receptionist',
          price: 'Starts at $5,000',
          desc: 'Complete 24/7 call handling with lead qualification, appointment booking, emergency triage, SMS follow-ups, and CRM integration.'
        };
      }
      if (answers.budget === 'mid') {
        return {
          label: 'SMART CALL ROUTING',
          name: 'Smart Call Routing',
          price: 'Starts at $3,000',
          desc: 'After-hours answering with lead qualification, appointment booking, and call summaries sent to your phone.'
        };
      }
      return {
        label: 'AFTER-HOURS ANSWERING',
        name: 'After-Hours Answering',
        price: 'Starts at $1,500',
        desc: 'AI answers calls when you can\u2019t, takes messages, and sends you a summary. Never miss a lead again.'
      };
    }

    /* ── Render Helpers ─────────────────────────────────── */

    function createLine() {
      var line = document.createElement('div');
      line.className = 'flow-line';
      return line;
    }

    function buildQuestionCard(step) {
      var card = document.createElement('div');
      card.className = 'flow-card';

      var title = document.createElement('h3');
      title.className = 'flow-card-title';
      title.textContent = step.title;
      card.appendChild(title);

      var opts = document.createElement('div');
      opts.className = 'flow-card-options';

      step.options.forEach(function(opt) {
        var btn = document.createElement('button');
        btn.className = 'flow-option';
        btn.textContent = opt.label;
        btn.dataset.value = opt.value;
        btn.addEventListener('click', function() {
          handleOptionClick(btn, opts, step.key, opt.value);
        });
        opts.appendChild(btn);
      });

      card.appendChild(opts);
      return card;
    }

    function buildInfoCard(step) {
      var card = document.createElement('div');
      card.className = 'flow-card';

      var text = document.createElement('p');
      text.className = 'flow-card-text';
      text.textContent = step.text;
      card.appendChild(text);

      var btn = document.createElement('button');
      btn.className = 'flow-continue';
      btn.textContent = step.continueLabel;
      btn.addEventListener('click', function() {
        btn.style.opacity = '0';
        btn.style.pointerEvents = 'none';
        advanceStep();
      });
      card.appendChild(btn);

      return card;
    }

    function buildExamplesCard(step) {
      var card = document.createElement('div');
      card.className = 'flow-card';

      var title = document.createElement('h3');
      title.className = 'flow-card-title';
      title.textContent = step.title;
      card.appendChild(title);

      var grid = document.createElement('div');
      grid.className = 'flow-examples';

      step.examples.forEach(function(ex) {
        var item = document.createElement('div');
        item.className = 'flow-example';

        var icon = document.createElement('div');
        icon.className = 'flow-example-icon';
        icon.innerHTML = ex.icon;
        item.appendChild(icon);

        var h4 = document.createElement('h4');
        h4.textContent = ex.title;
        item.appendChild(h4);

        var p = document.createElement('p');
        p.textContent = ex.desc;
        item.appendChild(p);

        grid.appendChild(item);
      });

      card.appendChild(grid);

      var btn = document.createElement('button');
      btn.className = 'flow-continue';
      btn.textContent = step.continueLabel;
      btn.addEventListener('click', function() {
        btn.style.opacity = '0';
        btn.style.pointerEvents = 'none';
        advanceStep();
      });
      card.appendChild(btn);

      return card;
    }

    function buildTiersCard(step) {
      var card = document.createElement('div');
      card.className = 'flow-card';

      var title = document.createElement('h3');
      title.className = 'flow-card-title';
      title.textContent = step.title;
      card.appendChild(title);

      var grid = document.createElement('div');
      grid.className = 'flow-tiers';

      var tiers = [
        { label: 'AFTER-HOURS ANSWERING', name: 'After-Hours Answering', price: '$1,500', desc: 'AI answers calls, takes messages, and sends summaries. Never miss a lead.' },
        { label: 'SMART CALL ROUTING', name: 'Smart Call Routing', price: '$3,000', desc: 'Lead qualification, appointment booking, and call summaries to your phone.' },
        { label: 'FULL AI RECEPTIONIST', name: 'Full AI Receptionist', price: '$5,000', desc: '24/7 handling with CRM integration, SMS follow-ups, and emergency triage.' }
      ];

      tiers.forEach(function(t) {
        var item = document.createElement('div');
        item.className = 'flow-tier';

        var label = document.createElement('p');
        label.className = 'flow-tier-label';
        label.textContent = t.label;
        item.appendChild(label);

        var h4 = document.createElement('h4');
        h4.textContent = t.name;
        item.appendChild(h4);

        var price = document.createElement('p');
        price.className = 'flow-tier-price';
        price.textContent = t.price;
        item.appendChild(price);

        var desc = document.createElement('p');
        desc.textContent = t.desc;
        item.appendChild(desc);

        grid.appendChild(item);
      });

      card.appendChild(grid);
      return card;
    }

    function buildResultCard() {
      var rec = getRecommendation();
      currentRec = rec;

      var card = document.createElement('div');
      card.className = 'flow-card';

      var result = document.createElement('div');
      result.className = 'flow-result';

      var eyebrow = document.createElement('p');
      eyebrow.className = 'flow-result-eyebrow';
      eyebrow.textContent = 'WE THINK WE SHOULD START THE CONVERSATION WITH...';
      result.appendChild(eyebrow);

      var h3 = document.createElement('h3');
      h3.textContent = rec.name;
      result.appendChild(h3);

      var price = document.createElement('p');
      price.className = 'flow-result-price';
      price.textContent = rec.price;
      result.appendChild(price);

      var desc = document.createElement('p');
      desc.textContent = rec.desc;
      result.appendChild(desc);

      card.appendChild(result);
      return card;
    }

    /* ── Flow Engine ────────────────────────────────────── */

    function renderStep(step) {
      var node = document.createElement('div');
      node.className = 'flow-node';

      var line = createLine();
      node.appendChild(line);

      var card;
      if (step.type === 'question') card = buildQuestionCard(step);
      else if (step.type === 'info') card = buildInfoCard(step);
      else if (step.type === 'examples') card = buildExamplesCard(step);
      else if (step.type === 'tiers') card = buildTiersCard(step);
      else if (step.type === 'result') card = buildResultCard();

      node.appendChild(card);
      flowContainer.appendChild(node);

      // Force browser to paint the element at height:0 first
      line.getBoundingClientRect();
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          line.classList.add('extending');
          setTimeout(function() {
            card.classList.add('visible');
            // Auto-advance after tiers card is visible
            if (step.type === 'tiers') {
              setTimeout(function() { advanceStep(); }, 2000);
            }
          }, 2000);
        });
      });
    }

    function revealContact() {
      var node = document.createElement('div');
      node.className = 'flow-node';
      var line = createLine();
      line.classList.add('arrow');
      node.appendChild(line);
      flowContainer.appendChild(node);

      requestAnimationFrame(function() {
        line.classList.add('extending');
        setTimeout(function() {
          contactSection.classList.remove('flow-contact-hidden');
          contactSection.classList.add('flow-contact-reveal');
          contactSection.getBoundingClientRect();
          contactSection.classList.add('flow-contact-visible');
          // Pre-select Design in the service dropdown
          var serviceSelect = document.getElementById('contact-service');
          if (serviceSelect) serviceSelect.value = 'ai';
          // Set recommended package hidden field
          var pkgField = document.getElementById('contact-recommended-package');
          if (pkgField && currentRec) pkgField.value = currentRec.name + ' (' + currentRec.price + ')';
          setTimeout(function() {
            // Let the user scroll naturally
          }, 200);
        }, 1000);
      });
    }

    function handleOptionClick(chosenBtn, optionsContainer, key, value) {
      answers[key] = value;

      var buttons = Array.from(optionsContainer.querySelectorAll('.flow-option'));
      var chosenIndex = buttons.indexOf(chosenBtn);

      // Calculate center offset for the chosen button
      var containerRect = optionsContainer.getBoundingClientRect();
      var chosenRect = chosenBtn.getBoundingClientRect();
      var containerCenterX = containerRect.left + containerRect.width / 2;
      var chosenCenterX = chosenRect.left + chosenRect.width / 2;
      var offsetX = containerCenterX - chosenCenterX;

      buttons.forEach(function(btn, i) {
        if (btn === chosenBtn) {
          btn.classList.add('chosen');
          btn.style.transform = 'translateX(' + offsetX + 'px)';
        } else {
          btn.classList.add('dismissed');
          btn.classList.add(i < chosenIndex ? 'dismissed-left' : 'dismissed-right');
        }
      });

      setTimeout(function() {
        advanceStep();
      }, 1000);
    }

    function advanceStep() {
      currentStepIndex++;
      var steps = currentPath === 'need' ? NEED_STEPS : WHAT_STEPS;

      if (currentStepIndex < steps.length) {
        renderStep(steps[currentStepIndex]);
      } else if (currentPath === 'need') {
        // Show result then contact
        renderStep({ type: 'result' });
        setTimeout(function() {
          revealContact();
        }, 2000);
      } else {
        // "what" path — go straight to contact after tiers
        setTimeout(function() {
          revealContact();
        }, 1500);
      }
    }

    function startFlow(path) {
      currentPath = path;
      currentStepIndex = 0;
      answers = {};
      var steps = path === 'need' ? NEED_STEPS : WHAT_STEPS;
      setTimeout(function() {
        renderStep(steps[0]);
      }, 600);
    }

    /* ── Chooser Button Handlers ────────────────────────── */

    function handleChoice(chosenBtn, dismissedBtn, path) {
      if (chosen) return;
      chosen = true;

      var containerRect = container.getBoundingClientRect();
      var chosenRect = chosenBtn.getBoundingClientRect();
      var dismissedRect = dismissedBtn.getBoundingClientRect();

      var containerCenterX = containerRect.left + containerRect.width / 2;
      var chosenCenterX = chosenRect.left + chosenRect.width / 2;
      var offsetX = containerCenterX - chosenCenterX;

      var dismissDirection = dismissedRect.left < chosenRect.left ? -1 : 1;
      var dismissX = dismissDirection * containerRect.width;

      dismissedBtn.style.transform = 'translateX(' + dismissX + 'px)';
      dismissedBtn.classList.add('dismissed');

      chosenBtn.style.transform = 'translateX(' + offsetX + 'px)';
      chosenBtn.classList.add('chosen');

      chooserLine.classList.add('hide-line');

      startFlow(path);
    }

    btnNeed.addEventListener('click', function() { handleChoice(btnNeed, btnWhat, 'need'); });
    btnWhat.addEventListener('click', function() { handleChoice(btnWhat, btnNeed, 'what'); });
  })();
  </script>

</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Booking System | Ice Cap Labs" description="Custom online booking for your business — without the monthly SaaS fees.">

  <!-- PIXEL HERO -->
  <section class="pixel-hero">
    <h1 class="pixel-hero-title" aria-label="Booking System">BOOKING SYSTEM</h1>
    <div class="pixel-title-grid" id="pixel-title-grid"></div>
  </section>

  <!-- OUTCOME STATEMENT -->
  <section>
    <div class="container">
      <div class="section-header reveal" style="max-width: 760px; margin-left: auto; margin-right: auto; text-align: center;">
        <p class="section-eyebrow">Booking System</p>
        <h2 class="section-title word-reveal" data-delay="0.05">
          Custom online booking for your business — without the monthly SaaS fees.
        </h2>
        <p class="section-subtitle">
          Built specifically for your services, your availability, and your brand. Customers book online, get confirmations automatically, and you get notified. You own it outright.
        </p>
      </div>
    </div>
  </section>

  <!-- WHAT YOU GET -->
  <section style="background: var(--bg-void); padding: 5rem 0;">
    <div class="container">
      <div class="section-header reveal" style="margin-bottom: 2.5rem; text-align: center;">
        <p class="section-eyebrow">What You Get</p>
      </div>
      <div class="pricing-card reveal">
        <div class="ai-columns">
          <div class="ai-card">
            <div class="ai-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
            </div>
            <h3 class="ai-heading">Custom Booking Page</h3>
            <p class="ai-copy">Your services, your availability, your brand. Not a generic template — built for how your business actually works.</p>
          </div>
          <div class="ai-card">
            <div class="ai-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <h3 class="ai-heading">Automatic Confirmations</h3>
            <p class="ai-copy">Customers get email confirmations the moment they book. You get notified too. No back-and-forth.</p>
          </div>
          <div class="ai-card">
            <div class="ai-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2"/>
                <path d="M3 9h18"/>
                <path d="m9 14 2 2 4-4"/>
              </svg>
            </div>
            <h3 class="ai-heading">Admin Calendar View</h3>
            <p class="ai-copy">See all upcoming bookings, manage your availability, and view customer details from a clean dashboard.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section style="padding: 5rem 0;">
    <div class="container">
      <div class="section-header reveal" style="margin-bottom: 2.5rem; text-align: center;">
        <p class="section-eyebrow">Pricing</p>
      </div>
      <div class="reveal" data-delay="0.1" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; max-width: 560px; margin: 0 auto;">
        <div style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 2rem; text-align: center;">
          <p style="font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent-bright); margin-bottom: 0.75rem;">Setup</p>
          <p style="font-size: 1.5rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.4rem;">$2,000 – $3,500</p>
          <p style="font-size: 0.85rem; color: var(--text-secondary);">One-time</p>
        </div>
        <div style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 2rem; text-align: center;">
          <p style="font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent-bright); margin-bottom: 0.75rem;">Monthly</p>
          <p style="font-size: 1.5rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.4rem;">$199 – $499</p>
          <p style="font-size: 0.85rem; color: var(--text-secondary);">Hosting, support, updates</p>
        </div>
      </div>
      <p class="reveal" data-delay="0.15" style="text-align: center; color: var(--text-secondary); font-size: 0.85rem; margin-top: 1.5rem; max-width: 400px; margin-left: auto; margin-right: auto;">Every build is custom. Final pricing reflects your scope.</p>
    </div>
  </section>

  <!-- DEMO CTA -->
  <section style="background: var(--bg-void); padding: 6rem 0; text-align: center;">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-eyebrow">Live Demo</p>
        <h2 class="section-title word-reveal" data-delay="0.05">See It Live</h2>
        <p class="section-subtitle">Try the real product. No signup required.</p>
      </div>
      <div class="reveal" data-delay="0.2">
        <a href="#" class="btn-primary" data-coming-soon="true">Open Demo →</a>
      </div>
    </div>
  </section>

</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookingWidget from '../components/BookingWidget.astro';
---
<BaseLayout title="Contact Ice Cap Labs | Wichita, KS" description="Contact Ice Cap Labs in Wichita, Kansas to talk about custom software for your small business, including lead capture tools, booking systems, AI chatbots, and internal dashboards.">

  <section id="contact-hero" style="background: var(--bg-void); padding-top: calc(64px + clamp(4rem, 8vw, 7rem)); padding-bottom: clamp(4rem, 8vw, 7rem);">
    <div class="container">
      <div class="contact-card-layout reveal" style="display: grid; grid-template-columns: 1.15fr 0.85fr; gap: clamp(2rem, 5vw, 5rem); align-items: stretch;">
        <div class="contact-card-panel" style="background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02)); border: 1px solid rgba(255,255,255,0.08); border-radius: 28px; padding: clamp(2rem, 4vw, 3rem); display: flex; flex-direction: column; justify-content: space-between; min-height: 520px;">
          <div>
            <p class="section-eyebrow" style="margin-bottom: 1rem;">Direct Contact</p>
            <h1 class="section-title word-reveal" data-delay="0.05" style="margin-bottom: 0.75rem;">Ice Cap Labs</h1>
            <p style="font-size: clamp(1.2rem, 2vw, 1.5rem); color: var(--text-bright); margin-bottom: 0.5rem;">Max Hinman</p>
            <p style="font-size: clamp(1rem, 1.8vw, 1.2rem); color: var(--accent-bright); margin-bottom: 2.5rem;">Custom Software for Small Businesses</p>

            <div style="display: grid; gap: 1.5rem; margin-bottom: 2.5rem;">
              <div>
                <p style="font-size: 0.78rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent-bright); margin-bottom: 0.45rem;">Phone</p>
                <a href="tel:+13166694468" style="font-size: clamp(1.5rem, 3vw, 2.4rem); color: var(--text-bright); text-decoration: none; font-weight: 600;">(316) 669-4468</a>
              </div>
              <div>
                <p style="font-size: 0.78rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent-bright); margin-bottom: 0.45rem;">Email</p>
                <a href="mailto:hello@icecaplabs.com" style="font-size: clamp(1.1rem, 2.2vw, 1.5rem); color: var(--text-bright); text-decoration: none; font-weight: 500; word-break: break-word;">hello@icecaplabs.com</a>
              </div>
              <div>
                <p style="font-size: 0.78rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent-bright); margin-bottom: 0.45rem;">Location</p>
                <p style="font-size: 1.05rem; color: var(--text-bright); margin: 0;">Wichita, Kansas</p>
              </div>
            </div>
          </div>

          <p style="max-width: 38rem; color: var(--text-main); margin: 0; line-height: 1.75;">
            I build custom software for small businesses that are tired of losing leads, chasing manual work, or forcing their process into software that was never designed for them. You work directly with me from the first conversation through delivery.
          </p>
        </div>

        <div class="contact-side-panel" style="display: flex; flex-direction: column; justify-content: center; gap: 1.5rem; padding: clamp(0.5rem, 1vw, 1rem) 0;">
          <div>
            <p class="section-eyebrow" style="margin-bottom: 1rem;">Capabilities</p>
            <h2 class="section-title word-reveal" data-delay="0.08" style="margin-bottom: 1rem;">What I Build</h2>
          </div>

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div style="padding: 1.5rem; border: 1px solid rgba(255,255,255,0.08); border-radius: 22px; background: linear-gradient(180deg, rgba(14,165,233,0.10), rgba(255,255,255,0.02)); min-height: 150px; display: flex; flex-direction: column; justify-content: space-between;">
              <p style="font-size: 0.78rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent-bright); margin: 0;">01</p>
              <div>
                <h3 style="margin: 0 0 0.45rem 0; color: var(--text-bright); font-size: 1.15rem;">Lead Capture</h3>
                <p style="margin: 0; color: var(--text-main); line-height: 1.6;">Landing pages and intake tools that turn interest into organized leads.</p>
              </div>
            </div>
            <div style="padding: 1.5rem; border: 1px solid rgba(255,255,255,0.08); border-radius: 22px; background: linear-gradient(180deg, rgba(14,165,233,0.10), rgba(255,255,255,0.02)); min-height: 150px; display: flex; flex-direction: column; justify-content: space-between;">
              <p style="font-size: 0.78rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent-bright); margin: 0;">02</p>
              <div>
                <h3 style="margin: 0 0 0.45rem 0; color: var(--text-bright); font-size: 1.15rem;">Booking Systems</h3>
                <p style="margin: 0; color: var(--text-main); line-height: 1.6;">Custom scheduling flows that fit the way your business actually books work.</p>
              </div>
            </div>
            <div style="padding: 1.5rem; border: 1px solid rgba(255,255,255,0.08); border-radius: 22px; background: linear-gradient(180deg, rgba(14,165,233,0.10), rgba(255,255,255,0.02)); min-height: 150px; display: flex; flex-direction: column; justify-content: space-between;">
              <p style="font-size: 0.78rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent-bright); margin: 0;">03</p>
              <div>
                <h3 style="margin: 0 0 0.45rem 0; color: var(--text-bright); font-size: 1.15rem;">AI Chatbots</h3>
                <p style="margin: 0; color: var(--text-main); line-height: 1.6;">Trained on your business, with lead capture and human handoff built in.</p>
              </div>
            </div>
            <div style="padding: 1.5rem; border: 1px solid rgba(255,255,255,0.08); border-radius: 22px; background: linear-gradient(180deg, rgba(14,165,233,0.10), rgba(255,255,255,0.02)); min-height: 150px; display: flex; flex-direction: column; justify-content: space-between;">
              <p style="font-size: 0.78rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent-bright); margin: 0;">04</p>
              <div>
                <h3 style="margin: 0 0 0.45rem 0; color: var(--text-bright); font-size: 1.15rem;">Internal Tools</h3>
                <p style="margin: 0; color: var(--text-main); line-height: 1.6;">Dashboards and software that clean up the messy work behind the scenes.</p>
              </div>
            </div>
          </div>

          <p style="margin: 0.5rem 0 0 0; color: var(--text-main); line-height: 1.7; max-width: 32rem;">
            Built directly with the owner. No handoffs. No bloated process.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- BOOKING WIDGET -->
  <section id="contact" style="background: var(--bg-void); padding: 6rem 0;">
    <div class="container">
      <div class="section-header reveal" style="margin-bottom: 3rem;">
        <p class="section-eyebrow">Book a Time</p>
        <h2 class="section-title word-reveal">Schedule a Call</h2>
        <p class="section-subtitle">
          Pick a time that works for you. The booking flow below is already connected and ready to go.
        </p>
      </div>
      <BookingWidget title="Schedule a Call" />
    </div>
  </section>

  <style>
    @media (max-width: 900px) {
      .contact-card-layout {
        grid-template-columns: 1fr !important;
      }

      .contact-card-panel {
        min-height: unset !important;
      }
    }
  </style>

</BaseLayout>

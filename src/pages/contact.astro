---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookingWidget from '../components/BookingWidget.astro';
---
<BaseLayout title="Contact Ice Cap Labs | Wichita, KS" description="Contact Ice Cap Labs in Wichita, Kansas to talk about custom software for your small business, including lead capture tools, booking systems, AI chatbots, and internal dashboards.">

  <section id="contact-hero" style="background: var(--bg-void); padding-top: calc(64px + clamp(4rem, 8vw, 7rem)); padding-bottom: clamp(4rem, 8vw, 7rem);">
    <div class="container">
      <div class="contact-card-layout reveal" style="display: grid; grid-template-columns: 1.15fr 0.85fr; gap: clamp(2rem, 5vw, 5rem); align-items: stretch;">
        <div class="contact-card-panel" style="background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02)); border: 1px solid rgba(255,255,255,0.08); border-radius: 28px; padding: clamp(2rem, 4vw, 3rem); display: flex; flex-direction: column; justify-content: space-between; min-height: 520px;">
          <div>
            <p class="section-eyebrow" style="margin-bottom: 1rem; color: #ffffff;">Direct Contact</p>
            <h1 class="section-title word-reveal" data-delay="0.05" style="margin-bottom: 0.75rem; color: #ffffff;">Ice Cap Labs</h1>
            <p style="font-size: clamp(1.2rem, 2vw, 1.5rem); color: #ffffff; margin-bottom: 0.5rem;">Max Hinman</p>
            <p style="font-size: clamp(1rem, 1.8vw, 1.2rem); color: #ffffff; margin-bottom: 2.5rem;">Custom Software for Small Businesses</p>

            <div style="display: grid; gap: 1.5rem; margin-bottom: 2.5rem;">
              <div>
                <p style="font-size: 0.78rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent-bright); margin-bottom: 0.45rem;">Phone</p>
                <a href="tel:+13166694468" style="font-size: clamp(1.5rem, 3vw, 2.4rem); color: #ffffff; text-decoration: none; font-weight: 600;">(316) 669-4468</a>
              </div>
              <div>
                <p style="font-size: 0.78rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent-bright); margin-bottom: 0.45rem;">Email</p>
                <a href="mailto:hello@icecaplabs.com" style="font-size: clamp(1.1rem, 2.2vw, 1.5rem); color: #ffffff; text-decoration: none; font-weight: 500; word-break: break-word;">hello@icecaplabs.com</a>
              </div>
              <div>
                <p style="font-size: 0.78rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent-bright); margin-bottom: 0.45rem;">Location</p>
                <p style="font-size: 1.05rem; color: #ffffff; margin: 0;">Wichita, Kansas</p>
              </div>
            </div>
          </div>

          <p style="max-width: 38rem; color: var(--text-main); margin: 0; line-height: 1.75;">
            I build custom software for small businesses that are tired of losing leads, chasing manual work, or forcing their process into software that was never designed for them. You work directly with me from the first conversation through delivery.
          </p>
        </div>

        <div class="contact-side-panel" style="display: flex; flex-direction: column; padding: clamp(0.5rem, 1vw, 1rem) 0; min-height: 100%;">
          <div style="padding: clamp(2rem, 4vw, 3rem); border: 1px solid rgba(255,255,255,0.08); border-radius: 28px; background: linear-gradient(180deg, rgba(14,165,233,0.14), rgba(255,255,255,0.03)); min-height: 100%; height: 100%; display: flex; flex-direction: column; justify-content: space-between;">
            <div>
              <p style="font-size: 0.85rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent-bright); margin: 0 0 1.5rem 0;">Small Businesses Need</p>
              <h2 style="font-size: clamp(3rem, 7vw, 5.8rem); line-height: 0.95; letter-spacing: -0.04em; margin: 0; color: #ffffff; font-weight: 700; text-transform: uppercase;">Custom<br />Software.</h2>
              <h2 style="font-size: clamp(3rem, 7vw, 5.8rem); line-height: 0.95; letter-spacing: -0.04em; margin: 0.35rem 0 0 0; color: var(--accent-bright); font-weight: 700; text-transform: uppercase;">No<br />Surprises.</h2>
            </div>

            <div>
              <p style="margin: 0; color: #ffffff; line-height: 1.75; font-size: 1.05rem; max-width: 30rem;">
                Lead capture, AI chatbots, booking systems, ops dashboards. Built for your business, by an actual programmer who answers his phone.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- BOOKING WIDGET -->
  <section id="contact" style="background: var(--bg-void); padding: 6rem 0;">
    <div class="container">
      <div class="section-header reveal" style="margin-bottom: 3rem;">
        <p class="section-eyebrow">Book a Time</p>
        <h2 class="section-title word-reveal">Schedule a Call</h2>
        <p class="section-subtitle">
          Pick a time that works for you. The booking flow below is already connected and ready to go.
        </p>
      </div>
      <BookingWidget title="Schedule a Call" />
    </div>
  </section>

  <style>
    @media (max-width: 900px) {
      .contact-card-layout {
        grid-template-columns: 1fr !important;
      }

      .contact-card-panel {
        min-height: unset !important;
      }
    }
  </style>

</BaseLayout>

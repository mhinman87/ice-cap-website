---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="AI Chatbot | Ice Cap Labs" description="A 24/7 AI receptionist that answers questions, captures leads, and never misses a customer.">

  <!-- PIXEL HERO -->
  <section class="pixel-hero">
    <h1 class="pixel-hero-title" aria-label="AI Chatbot">AI CHATBOT</h1>
    <div class="pixel-title-grid" id="pixel-title-grid"></div>
  </section>

  <!-- OUTCOME STATEMENT -->
  <section>
    <div class="container">
      <div class="section-header reveal" style="max-width: 760px; margin-left: auto; margin-right: auto; text-align: center;">
        <p class="section-eyebrow">AI Chatbot</p>
        <h2 class="section-title word-reveal" data-delay="0.05">
          A 24/7 AI receptionist that answers questions, captures leads, and never misses a customer.
        </h2>
        <p class="section-subtitle">
          Trained on your business — your hours, services, pricing, and FAQs. When a visitor wants a human, it captures their contact info and notifies you instantly.
        </p>
      </div>
    </div>
  </section>

  <!-- WHAT YOU GET -->
  <section style="background: var(--bg-void); padding: 5rem 0;">
    <div class="container">
      <div class="section-header reveal" style="margin-bottom: 2.5rem; text-align: center;">
        <p class="section-eyebrow">What You Get</p>
      </div>
      <div class="pricing-card reveal">
        <div class="ai-columns">
          <div class="ai-card">
            <div class="ai-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            </div>
            <h3 class="ai-heading">Answers Customer Questions</h3>
            <p class="ai-copy">Trained on your knowledge base. Handles the questions you answer 10 times a day so you don't have to.</p>
          </div>
          <div class="ai-card">
            <div class="ai-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </div>
            <h3 class="ai-heading">Captures Warm Leads</h3>
            <p class="ai-copy">Naturally offers a human follow-up mid-conversation. No pushy popups — just a natural offer.</p>
          </div>
          <div class="ai-card">
            <div class="ai-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="20" x2="18" y2="10"/>
                <line x1="12" y1="20" x2="12" y2="4"/>
                <line x1="6" y1="20" x2="6" y2="14"/>
              </svg>
            </div>
            <h3 class="ai-heading">Admin Dashboard</h3>
            <p class="ai-copy">See every conversation, update your knowledge base, and manage leads — no technical knowledge needed.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section style="padding: 5rem 0;">
    <div class="container">
      <div class="section-header reveal" style="margin-bottom: 2.5rem; text-align: center;">
        <p class="section-eyebrow">Pricing</p>
      </div>
      <div class="reveal" data-delay="0.1" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; max-width: 560px; margin: 0 auto;">
        <div style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 2rem; text-align: center;">
          <p style="font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent-bright); margin-bottom: 0.75rem;">Setup</p>
          <p style="font-size: 1.5rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.4rem;">$2,000 – $4,000</p>
          <p style="font-size: 0.85rem; color: var(--text-secondary);">One-time</p>
        </div>
        <div style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 2rem; text-align: center;">
          <p style="font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent-bright); margin-bottom: 0.75rem;">Monthly</p>
          <p style="font-size: 1.5rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.4rem;">$299 – $799</p>
          <p style="font-size: 0.85rem; color: var(--text-secondary);">Hosting, support, updates</p>
        </div>
      </div>
      <p class="reveal" data-delay="0.15" style="text-align: center; color: var(--text-secondary); font-size: 0.85rem; margin-top: 1.5rem; max-width: 400px; margin-left: auto; margin-right: auto;">Every build is custom. Final pricing reflects your scope.</p>
    </div>
  </section>

  <!-- DEMO CTA -->
  <section style="background: var(--bg-void); padding: 6rem 0; text-align: center;">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-eyebrow">Live Demo</p>
        <h2 class="section-title word-reveal" data-delay="0.05">See It Live</h2>
        <p class="section-subtitle">Try the real product. No signup required.</p>
      </div>
      <div class="reveal" data-delay="0.2">
        <a href="#" class="btn-primary" data-coming-soon="true">Open Demo →</a>
      </div>
    </div>
  </section>

</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Design — Ice Cap Labs" description="Strategic design services from Ice Cap Labs — brand identity, UI/UX, marketing collateral, and experience design.">

  <!-- DESIGN HERO -->
  <section class="pixel-hero">
    <h1 class="pixel-hero-title" aria-label="Design">DESIGN</h1>
    <div class="pixel-title-grid" id="pixel-title-grid"></div>
  </section>

  <!-- SERVICE DETAILS -->
  <section class="blocks-section" style="background: var(--bg-deep);">
    <div class="blocks-container">
      <div class="service-block reveal">
        <div class="block-inner">
          <div>
            <p class="block-number">Strategic Design</p>
            <h2 class="block-title">Design That Drives Decisions</h2>
          </div>
          <div>
            <p class="block-desc">
              Design that does more than look good — it communicates brand clarity, builds trust, and drives customer decisions. From brand identity to UI/UX, every visual touchpoint is intentional.
            </p>
            <ul class="block-list">
              <li>Brand identity and logo design</li>
              <li>UI/UX design for web and mobile</li>
              <li>Marketing collateral and print design</li>
              <li>Presentation and pitch deck design</li>
              <li>Design systems and style guides</li>
              <li>Customer journey mapping and experience design</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="page-cta reveal">
    <h2>Ready to Start?</h2>
    <p>Let's talk about what your brand needs and build something that stands out.</p>
    <a href="/contact" class="btn-primary">Get Started</a>
  </section>

</BaseLayout>

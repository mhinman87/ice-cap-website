---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCard from '../components/ContactCard.astro';
---
<BaseLayout title="Ice Cap Labs — Your Full-Stack Technology Partner" description="Ice Cap Labs combines web development, digital marketing, AI automation, and strategic design to modernize small businesses." footerSpeed="0.75">

  <!-- HERO -->
  <section id="hero">
    <div id="cursor-spotlight" aria-hidden="true"></div>
    <div class="hero-ambient" aria-hidden="true"></div>

    <!-- PARALLAX LAYERS -->
    <div id="parallax-container" aria-hidden="true">
      <div class="parallax-layer layer-6" data-speed="0"></div>
      <div class="parallax-layer layer-5" data-speed="0.05"></div>
      <div class="parallax-layer layer-4" data-speed="0.15"></div>
      <div class="parallax-layer layer-3" data-speed="0.3"></div>
      <div class="parallax-layer layer-2" data-speed="0.5"></div>
      <div class="parallax-layer layer-1" data-speed="0.75"></div>
    </div>

    <div class="hero-content">
      <h1 class="hero-title word-reveal" data-delay="0.15">Modernize. Grow. Compete.</h1>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" data-speed="0.75">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-eyebrow">What We Do</p>
        <h2 class="section-title word-reveal" data-delay="0.05">Built for Modern Business</h2>
        <p class="section-subtitle">
          Every service we offer is designed to solve a real problem that small businesses
          face when trying to grow and compete in a digital market.
        </p>
      </div>

      <div class="services-grid">
        <a href="/develop" class="service-card reveal" data-delay="0.0">
          <div class="service-card-inner">
            <div class="service-card-front">
              <div class="service-icon-wrap">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="16 18 22 12 16 6"/>
                  <polyline points="8 6 2 12 8 18"/>
                </svg>
              </div>
              <h3>Web &amp; Software Development</h3>
            </div>
            <div class="service-card-back">
              <p>Custom websites, mobile applications, and tailored software built specifically for your workflows — not generic platforms that almost fit.</p>
            </div>
          </div>
        </a>

        <a href="/marketing" class="service-card reveal" data-delay="0.15">
          <div class="service-card-inner">
            <div class="service-card-front">
              <div class="service-icon-wrap">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/>
                  <polyline points="16 7 22 7 22 13"/>
                </svg>
              </div>
              <h3>Digital Marketing &amp; SEO</h3>
            </div>
            <div class="service-card-back">
              <p>Search engine optimization, digital marketing strategy, and social media automation designed to increase visibility while reducing the manual effort required.</p>
            </div>
          </div>
        </a>

        <a href="/automate" class="service-card reveal" data-delay="0.3">
          <div class="service-card-inner">
            <div class="service-card-front">
              <div class="service-icon-wrap">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                </svg>
              </div>
              <h3>AI Automation</h3>
            </div>
            <div class="service-card-back">
              <p>Practical AI integrations that save time and reduce repetitive work. Simple, reliable automations that deliver measurable value — not experimental hype.</p>
            </div>
          </div>
        </a>

        <a href="/design" class="service-card reveal" data-delay="0.45">
          <div class="service-card-inner">
            <div class="service-card-front">
              <div class="service-icon-wrap">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                  <path d="M2 17l10 5 10-5"/>
                  <path d="M2 12l10 5 10-5"/>
                </svg>
              </div>
              <h3>Strategic Design</h3>
            </div>
            <div class="service-card-back">
              <p>Design that communicates brand clarity and drives customer decisions — from brand identity to UI and every customer-facing touchpoint in between.</p>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- HOW WE WORK -->
  <section id="process" data-speed="0.75">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-eyebrow">How It Works</p>
        <h2 class="section-title word-reveal" data-delay="0.05">A Clear Path Forward</h2>
        <p class="section-subtitle">
          No black boxes, no endless discovery calls. We move efficiently from understanding
          your business to building and launching things that work.
        </p>
      </div>

      <div class="process-steps" id="process-steps">
        <div class="process-line-wrap" aria-hidden="true">
          <div class="process-line-bg"></div>
          <div class="process-line-fill" id="process-line-fill"></div>
        </div>
        <div class="process-step" data-step="1">
          <div class="step-number-wrap">01</div>
          <h3 class="step-title">Discover</h3>
          <p class="step-desc">We learn your business, goals, and gaps. No jargon — just listening and honest assessment.</p>
        </div>
        <div class="process-step" data-step="2">
          <div class="step-number-wrap">02</div>
          <h3 class="step-title">Design</h3>
          <p class="step-desc">We architect a technology strategy tailored to your size, your customers, and your budget.</p>
        </div>
        <div class="process-step" data-step="3">
          <div class="step-number-wrap">03</div>
          <h3 class="step-title">Build &amp; Launch</h3>
          <p class="step-desc">Development, marketing systems, and automation deployed. You see progress at every step.</p>
        </div>
        <div class="process-step" data-step="4">
          <div class="step-number-wrap">04</div>
          <h3 class="step-title">Grow</h3>
          <p class="step-desc">Ongoing support, optimization, and expansion as your business scales. We grow with you.</p>
        </div>
      </div>

      <div class="process-cta-wrap">
        <a href="/process" class="btn-primary process-cta" id="process-cta">See How It Works</a>
      </div>
    </div>
  </section>

  <!-- WHY ICE CAP LABS -->
  <section id="why" data-speed="0.75">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-eyebrow">Why Ice Cap Labs</p>
        <h2 class="section-title word-reveal" data-delay="0.05">One Partner. Full Stack.</h2>
        <p class="section-subtitle">
          Most agencies specialize. Most consultants are expensive. Ice Cap Labs is built to
          be the technology partner that small businesses actually need.
        </p>
      </div>

      <div class="why-grid">
        <div class="why-item reveal" data-delay="0.0">
          <div class="why-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
          </div>
          <div>
            <h3>No Overhead Bloat</h3>
            <p>You get a senior team without the in-house cost of hiring, benefits, and management overhead.</p>
          </div>
        </div>

        <div class="why-item reveal" data-delay="0.05">
          <div class="why-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
              <line x1="8" y1="21" x2="16" y2="21"/>
              <line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
          </div>
          <div>
            <h3>One Partner, Full Stack</h3>
            <p>Development, marketing, AI, and design under one roof. No coordinating between multiple agencies.</p>
          </div>
        </div>

        <div class="why-item reveal" data-delay="0.1">
          <div class="why-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <div>
            <h3>Built for Small Business</h3>
            <p>No enterprise pricing. No enterprise complexity. Solutions sized and priced for where you actually are.</p>
          </div>
        </div>

        <div class="why-item reveal" data-delay="0.15">
          <div class="why-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
            </svg>
          </div>
          <div>
            <h3>Practical AI, Not Hype</h3>
            <p>Automations that actually save you hours per week — not experimental demos that look impressive and deliver nothing.</p>
          </div>
        </div>

        <div class="why-item reveal" data-delay="0.2">
          <div class="why-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" y1="8" x2="12" y2="12"/>
              <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
          </div>
          <div>
            <h3>Strategic Thinking</h3>
            <p>We think about your business model, not just your current task list. Technology should serve your strategy.</p>
          </div>
        </div>

        <div class="why-item reveal" data-delay="0.25">
          <div class="why-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </div>
          <div>
            <h3>Transparent Process</h3>
            <p>You see everything. No black boxes, no mystery retainers. Clear deliverables and honest communication at every stage.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT / CTA -->
  <section id="contact" data-speed="0.75">
    <div class="container">
      <ContactCard />
    </div>
  </section>

</BaseLayout>

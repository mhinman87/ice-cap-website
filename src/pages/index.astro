---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCard from '../components/ContactCard.astro';
import BookingWidget from '../components/BookingWidget.astro';
---
<BaseLayout title="AI Integration for Small Businesses | Ice Cap Labs" description="Practical AI integration for small businesses. Lead capture, scheduling, CRM workflows, customer communication, and custom automation that saves time and reduces admin." footerSpeed="0.75">

  <!-- HERO -->
  <section id="hero">
    <div id="cursor-spotlight" aria-hidden="true"></div>
    <div class="hero-ambient" aria-hidden="true"></div>

    <!-- PARALLAX LAYERS -->
    <div id="parallax-container" aria-hidden="true">
      <div class="parallax-layer layer-6" data-speed="0"></div>
      <div class="parallax-layer layer-5" data-speed="0.05"></div>
      <div class="parallax-layer layer-4" data-speed="0.15"></div>
      <div class="parallax-layer layer-3" data-speed="0.3"></div>
      <div class="parallax-layer layer-2" data-speed="0.5"></div>
      <div class="parallax-layer layer-1" data-speed="0.75"></div>
    </div>

    <div class="hero-content">
      <h1 class="hero-title word-reveal" data-delay="0.15">Custom Software</h1>
      <h1 class="hero-title word-reveal" data-delay="0.3">for Small Businesses</h1>
    </div>
  </section>

  <!-- AI OPERATOR -->
  <section id="pricing" data-speed="0.75" style="display: none;">
    <div class="container">
      <div class="pricing-card reveal">
        <p class="pricing-eyebrow">HOW THIS WORKS</p>
        <h2 class="pricing-title">Practical AI Help for Small Businesses</h2>
        <div class="ai-columns">
          <div class="ai-card">
            <div class="ai-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="7" height="7" rx="1.5"></rect>
                <rect x="14" y="4" width="7" height="7" rx="1.5"></rect>
                <rect x="8.5" y="13" width="7" height="7" rx="1.5"></rect>
                <path d="M10 7.5h4"></path>
                <path d="M17.5 11v2"></path>
                <path d="M6.5 11v2"></path>
              </svg>
            </div>
            <h3 class="ai-heading">The Programmer Advantage</h3>
            <p class="ai-copy">Custom software used to cost $30,000 and take six months. AI tools let a skilled programmer build the same thing in days. That's what Ice Cap Labs is — that programmer, at a price that finally makes sense.</p>
          </div>

          <div class="ai-card">
            <div class="ai-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 3v18"></path>
                <path d="M3 12h18"></path>
                <circle cx="12" cy="12" r="8"></circle>
              </svg>
            </div>
            <h3 class="ai-heading">Direct Access</h3>
            <p class="ai-copy">We work with a small number of businesses at a time so every client gets direct access. No account managers, no handoffs — just results.</p>
          </div>

          <div class="ai-card">
            <div class="ai-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 7h16"></path>
                <path d="M4 12h10"></path>
                <path d="M4 17h7"></path>
                <circle cx="18" cy="16" r="3"></circle>
                <path d="m20.5 18.5 1.5 1.5"></path>
              </svg>
            </div>
            <h3 class="ai-heading">Real Problems. Real Fixes.</h3>
            <p class="ai-copy">If something is broken or slowing your business down, there's a real diagnosis and a real fix. Not a template. Not a workaround. A solution built specifically for how your business works.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" data-speed="0.75">
    <div class="container">
      <div class="section-header reveal">
        <h2 class="section-title word-reveal" data-delay="0.05">What We Build and Automate</h2>
        <p class="section-subtitle" style="margin-top: 1rem; color: var(--text-primary); max-width: 640px; margin-left: auto; margin-right: auto;">
         
        </p>
      </div>

      <div class="services-grid">
        <a href="/lead-automation" class="service-card reveal" data-delay="0.0" data-card-url="/lead-automation">
          <div class="service-card-inner">
            <div class="service-card-front">
              <div class="service-icon-wrap">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="3" width="20" height="14" rx="2"/>
                  <path d="M8 21h8"/>
                  <path d="M12 17v4"/>
                  <path d="M2 7h20"/>
                </svg>
              </div>
              <h3>Lead Capture</h3>
            </div>
            <div class="service-card-back">
              <p>A branded landing page that turns website visitors into leads automatically. Every submission saved, every lead followed up — 24/7.</p>
              <button class="card-learn-more">See Product →</button>
            </div>
          </div>
        </a>

        <a href="/customer-automation" class="service-card reveal" data-delay="0.15" data-card-url="/customer-automation">
          <div class="service-card-inner">
            <div class="service-card-front">
              <div class="service-icon-wrap">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                </svg>
              </div>
              <h3>AI Chatbot</h3>
            </div>
            <div class="service-card-back">
              <p>A 24/7 AI receptionist on your website. Answers questions, captures leads, and notifies you the moment a customer wants a human.</p>
              <button class="card-learn-more">See Product →</button>
            </div>
          </div>
        </a>

        <a href="/call-assistant" class="service-card reveal" data-delay="0.3" data-card-url="/call-assistant">
          <div class="service-card-inner">
            <div class="service-card-front">
              <div class="service-icon-wrap">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                  <line x1="16" y1="2" x2="16" y2="6"/>
                  <line x1="8" y1="2" x2="8" y2="6"/>
                  <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
              </div>
              <h3>Booking System</h3>
            </div>
            <div class="service-card-back">
              <p>Custom branded booking page with service selection, time slots, and automatic confirmations. Your own Calendly — without the monthly fee.</p>
              <button class="card-learn-more">See Product →</button>
            </div>
          </div>
        </a>
      </div>
      <div class="services-more-link">
        <a href="/products">See all products →</a>
      </div>
    </div>
  </section>

  <!-- HOW WE WORK -->
  <section id="process" data-speed="0.75">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-eyebrow">How It Works</p>
        <h2 class="section-title word-reveal" data-delay="0.05">From Call to Install in 4 Steps</h2>
        <p class="section-subtitle">
          No black boxes, no endless discovery calls. We move efficiently from understanding
          your pain points to launching automation that saves you hours every week.
        </p>
      </div>

      <div class="process-steps" id="process-steps">
        <div class="process-line-wrap" aria-hidden="true">
          <div class="process-line-bg"></div>
          <div class="process-line-fill" id="process-line-fill"></div>
        </div>
        <div class="process-step" data-step="1">
          <div class="step-number-wrap">01</div>
          <h3 class="step-title">Discover</h3>
          <p class="step-desc">We learn where you're losing time and money. No jargon — just listening and honest assessment of what automation can fix.</p>
        </div>
        <div class="process-step" data-step="2">
          <div class="step-number-wrap">02</div>
          <h3 class="step-title">Design</h3>
          <p class="step-desc">We architect an automation system tailored to your workflows, your team size, and your budget.</p>
        </div>
        <div class="process-step" data-step="3">
          <div class="step-number-wrap">03</div>
          <h3 class="step-title">Build &amp; Launch</h3>
          <p class="step-desc">Your AI systems are built, tested, and deployed. You see progress at every step and approve before we go live.</p>
        </div>
        <div class="process-step" data-step="4">
          <div class="step-number-wrap">04</div>
          <h3 class="step-title">Optimize</h3>
          <p class="step-desc">Ongoing monitoring, refinement, and expansion as your business scales. We grow with you and add new automations as needs arise.</p>
        </div>
      </div>

      <div class="process-cta-wrap">
        <a href="/process" class="btn-primary process-cta" id="process-cta">See How It Works</a>
      </div>
    </div>
  </section>

  <!-- CONTACT / CTA -->
  <section id="contact" data-speed="0.75" style="display: none;">
    <div class="container">
      <ContactCard />
    </div>
  </section>

  <!-- BOOKING WIDGET -->
  <section id="booking" data-speed="0.75" style="background: var(--bg-void); padding: 6rem 0;">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-eyebrow">Live Demo</p>
        <h2 class="section-title word-reveal" data-delay="0.05">Book a Call</h2>
        <p class="section-subtitle">
          See our booking automation in action. This widget integrates with Google Calendar, captures your info, and sends you a confirmation — automatically.
        </p>
      </div>
      <div class="reveal" data-delay="0.2">
        <BookingWidget title="Schedule Your Discovery Call" />
      </div>
    </div>
  </section>

  <style is:global>
    .services-more-link {
      text-align: center;
      margin-top: 2.5rem;
    }

    .services-more-link a {
      color: var(--accent);
      font-size: 0.95rem;
      font-weight: 500;
      text-decoration: none;
      letter-spacing: 0.01em;
      transition: color 0.2s ease, opacity 0.2s ease;
    }

    .services-more-link a:hover {
      color: var(--accent-bright);
    }
  </style>

</BaseLayout>

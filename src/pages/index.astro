---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCard from '../components/ContactCard.astro';
import BookingWidget from '../components/BookingWidget.astro';
---
<BaseLayout title="Wichita AI Automation for Service Businesses | Ice Cap Labs" description="Ice Cap Labs helps Wichita service businesses capture more jobs and reduce admin with practical AI call handling, lead follow-up, scheduling, and workflow automation." footerSpeed="0.75">

  <!-- HERO -->
  <section id="hero">
    <div id="cursor-spotlight" aria-hidden="true"></div>
    <div class="hero-ambient" aria-hidden="true"></div>

    <!-- PARALLAX LAYERS -->
    <div id="parallax-container" aria-hidden="true">
      <div class="parallax-layer layer-6" data-speed="0"></div>
      <div class="parallax-layer layer-5" data-speed="0.05"></div>
      <div class="parallax-layer layer-4" data-speed="0.15"></div>
      <div class="parallax-layer layer-3" data-speed="0.3"></div>
      <div class="parallax-layer layer-2" data-speed="0.5"></div>
      <div class="parallax-layer layer-1" data-speed="0.75"></div>
    </div>

    <div class="hero-content">
      <h1 class="hero-title word-reveal" data-delay="0.15">Wichita AI Automation</h1>
      <h1 class="hero-title word-reveal" data-delay="0.3">for Service Businesses</h1>
    </div>
  </section>

  <!-- AI OPERATOR -->
  <section id="pricing" data-speed="0.75">
    <div class="container">
      <div class="pricing-card reveal">
        <p class="pricing-eyebrow">HOW THIS WORKS</p>
        <h2 class="pricing-title">Capture More Jobs. Reduce Admin. Scale with AI.</h2>
        <div class="ai-columns">
          <div class="ai-card">
            <div class="ai-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="7" height="7" rx="1.5"></rect>
                <rect x="14" y="4" width="7" height="7" rx="1.5"></rect>
                <rect x="8.5" y="13" width="7" height="7" rx="1.5"></rect>
                <path d="M10 7.5h4"></path>
                <path d="M17.5 11v2"></path>
                <path d="M6.5 11v2"></path>
              </svg>
            </div>
            <h3 class="ai-heading">Revenue Operations Focus</h3>
            <p class="ai-copy">We prioritize the workflows that make or lose revenue first: missed calls, slow lead response, manual scheduling, and disconnected follow-up.</p>
          </div>

          <div class="ai-card">
            <div class="ai-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 3v18"></path>
                <path d="M3 12h18"></path>
                <circle cx="12" cy="12" r="8"></circle>
              </svg>
            </div>
            <h3 class="ai-heading">Practical Rollout</h3>
            <p class="ai-copy">We start with one high-impact automation, launch fast, and expand after results are proven. <a href="/about" style="color: var(--accent); text-decoration: underline;">See how we work</a>.</p>
          </div>

          <div class="ai-card">
            <div class="ai-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 7h16"></path>
                <path d="M4 12h10"></path>
                <path d="M4 17h7"></path>
                <circle cx="18" cy="16" r="3"></circle>
                <path d="m20.5 18.5 1.5 1.5"></path>
              </svg>
            </div>
            <h3 class="ai-heading">Built for Your Workflow</h3>
            <p class="ai-copy">No generic template dump. We connect AI to your current tools and team process so the system actually gets used day-to-day.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" data-speed="0.75">
    <div class="container">
      <div class="section-header reveal">
        <h2 class="section-title word-reveal" data-delay="0.05">What We Build and Automate</h2>
        <p class="section-subtitle" style="margin-top: 1rem; color: var(--text-primary); max-width: 640px; margin-left: auto; margin-right: auto;">
          We help Wichita teams automate the daily bottlenecks that cost time, delay follow-up, and leave revenue on the table.
        </p>
      </div>

      <div class="services-grid">
        <a href="/contact" class="service-card reveal" data-delay="0.0" data-card-url="/contact">
          <div class="service-card-inner">
            <div class="service-card-front">
              <div class="service-icon-wrap">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="4" y="3" width="16" height="18" rx="2"/>
                  <path d="M8 3v2"/>
                  <path d="M16 3v2"/>
                  <path d="M4 9h16"/>
                  <path d="m9 14 2 2 4-4"/>
                </svg>
              </div>
              <h3>Personal Assistant</h3>
            </div>
            <div class="service-card-back">
              <p>Morning briefs about your business, email management and replies, calendar coordination — your own personal AI helper.</p>
              <button class="card-learn-more">Learn More →</button>
            </div>
          </div>
        </a>

        <a href="/call-assistant" class="service-card reveal" data-delay="0.15" data-card-url="/call-assistant">
          <div class="service-card-inner">
            <div class="service-card-front">
              <div class="service-icon-wrap">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                </svg>
              </div>
              <h3>Voice Agents</h3>
            </div>
            <div class="service-card-back">
              <p>Answer phone calls and help customers 24/7 — book appointments, qualify leads, and handle the after-hours rush automatically.</p>
              <button class="card-learn-more">Learn More →</button>
            </div>
          </div>
        </a>

        <a href="/operations-automation" class="service-card reveal" data-delay="0.3" data-card-url="/operations-automation">
          <div class="service-card-inner">
            <div class="service-card-front">
              <div class="service-icon-wrap">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="3"/>
                  <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                </svg>
              </div>
              <h3>Employee Automation</h3>
            </div>
            <div class="service-card-back">
              <p>Watch inventory, take action, and complete tasks inside your business — trained like an employee to do real work, not just answer questions.</p>
              <button class="card-learn-more">Learn More →</button>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- HOW WE WORK -->
  <section id="process" data-speed="0.75">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-eyebrow">How It Works</p>
        <h2 class="section-title word-reveal" data-delay="0.05">From Call to Install in 4 Steps</h2>
        <p class="section-subtitle">
          No black boxes, no endless discovery calls. We move efficiently from understanding
          your pain points to launching automation that saves you hours every week.
        </p>
      </div>

      <div class="process-steps" id="process-steps">
        <div class="process-line-wrap" aria-hidden="true">
          <div class="process-line-bg"></div>
          <div class="process-line-fill" id="process-line-fill"></div>
        </div>
        <div class="process-step" data-step="1">
          <div class="step-number-wrap">01</div>
          <h3 class="step-title">Discover</h3>
          <p class="step-desc">We learn where you're losing time and money. No jargon — just listening and honest assessment of what automation can fix.</p>
        </div>
        <div class="process-step" data-step="2">
          <div class="step-number-wrap">02</div>
          <h3 class="step-title">Design</h3>
          <p class="step-desc">We architect an automation system tailored to your workflows, your team size, and your budget.</p>
        </div>
        <div class="process-step" data-step="3">
          <div class="step-number-wrap">03</div>
          <h3 class="step-title">Build &amp; Launch</h3>
          <p class="step-desc">Your AI systems are built, tested, and deployed. You see progress at every step and approve before we go live.</p>
        </div>
        <div class="process-step" data-step="4">
          <div class="step-number-wrap">04</div>
          <h3 class="step-title">Optimize</h3>
          <p class="step-desc">Ongoing monitoring, refinement, and expansion as your business scales. We grow with you and add new automations as needs arise.</p>
        </div>
      </div>

      <div class="process-cta-wrap">
        <a href="/process" class="btn-primary process-cta" id="process-cta">See How It Works</a>
      </div>
    </div>
  </section>

  <!-- CONTACT / CTA -->
  <section id="contact" data-speed="0.75" style="display: none;">
    <div class="container">
      <ContactCard />
    </div>
  </section>

  <!-- BOOKING WIDGET -->
  <section id="booking" data-speed="0.75" style="background: var(--bg-void); padding: 6rem 0;">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-eyebrow">Live Demo</p>
        <h2 class="section-title word-reveal" data-delay="0.05">Book a Call</h2>
        <p class="section-subtitle">
          See our booking automation in action. This widget integrates with Google Calendar, captures your info, and sends you a confirmation — automatically.
        </p>
      </div>
      <div class="reveal" data-delay="0.2">
        <BookingWidget calLink="ice-cap-labs-lnw3hf/30min" title="Schedule Your Discovery Call" />
      </div>
    </div>
  </section>

</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCard from '../components/ContactCard.astro';
import BookingWidget from '../components/BookingWidget.astro';
---
<BaseLayout title="AI Integration for Small Businesses | Ice Cap Labs" description="Practical AI integration for small businesses. Lead capture, scheduling, CRM workflows, customer communication, and custom automation that saves time and reduces admin." footerSpeed="0.75">

  <!-- HERO -->
  <section id="hero">
    <div id="cursor-spotlight" aria-hidden="true"></div>
    <div class="hero-ambient" aria-hidden="true"></div>

    <!-- PARALLAX LAYERS -->
    <div id="parallax-container" aria-hidden="true">
      <div class="parallax-layer layer-6" data-speed="0"></div>
      <div class="parallax-layer layer-5" data-speed="0.05"></div>
      <div class="parallax-layer layer-4" data-speed="0.15"></div>
      <div class="parallax-layer layer-3" data-speed="0.3"></div>
      <div class="parallax-layer layer-2" data-speed="0.5"></div>
      <div class="parallax-layer layer-1" data-speed="0.75"></div>
    </div>

    <div class="hero-content">
      <h1 class="hero-title word-reveal" data-delay="0.15">AI Integration</h1>
      <h1 class="hero-title word-reveal" data-delay="0.3">for Small Businesses</h1>
    </div>
  </section>

  <!-- AI OPERATOR -->
  <section id="pricing" data-speed="0.75">
    <div class="container">
      <div class="pricing-card reveal">
        <p class="pricing-eyebrow">HOW THIS WORKS</p>
        <h2 class="pricing-title">Practical AI Help for Small Businesses</h2>
        <div class="ai-columns">
          <div class="ai-card">
            <div class="ai-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="7" height="7" rx="1.5"></rect>
                <rect x="14" y="4" width="7" height="7" rx="1.5"></rect>
                <rect x="8.5" y="13" width="7" height="7" rx="1.5"></rect>
                <path d="M10 7.5h4"></path>
                <path d="M17.5 11v2"></path>
                <path d="M6.5 11v2"></path>
              </svg>
            </div>
            <h3 class="ai-heading">AI Operators</h3>
            <p class="ai-copy">Small businesses are going to need someone who can actually automate and manage how AI gets used inside the business. That new role is the AI operator.</p>
          </div>

          <div class="ai-card">
            <div class="ai-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 3v18"></path>
                <path d="M3 12h18"></path>
                <circle cx="12" cy="12" r="8"></circle>
              </svg>
            </div>
            <h3 class="ai-heading">Start Here</h3>
            <p class="ai-copy">I’m just getting started, and I’m looking to help a few businesses in exchange for a review, referral, or open door. <a href="/about" style="color: var(--accent); text-decoration: underline;">Learn more about me</a>.</p>
          </div>

          <div class="ai-card">
            <div class="ai-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 7h16"></path>
                <path d="M4 12h10"></path>
                <path d="M4 17h7"></path>
                <circle cx="18" cy="16" r="3"></circle>
                <path d="m20.5 18.5 1.5 1.5"></path>
              </svg>
            </div>
            <h3 class="ai-heading">Not Plug-and-Play</h3>
            <p class="ai-copy">Nobody knows exactly where AI is going, but we do know it is not as simple as flipping a switch. Every useful system is custom, and getting it right inside a business is a big deal.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" data-speed="0.75">
    <div class="container">
      <div class="section-header reveal">
        <h2 class="section-title word-reveal" data-delay="0.05">What We Build and Automate</h2>
        <p class="section-subtitle" style="margin-top: 1rem; color: var(--text-secondary); max-width: 600px; margin-left: auto; margin-right: auto;">
          We connect AI to the systems you already use, including monday.com, Hubspot, Pipedrive, Google Calendar, and <a href="/integrations" style="color: var(--accent); text-decoration: underline;">50+ other tools</a>
        </p>
      </div>

      <div class="services-grid">
        <a href="/call-assistant" class="service-card reveal" data-delay="0.0" data-card-url="/call-assistant">
          <div class="service-card-inner">
            <div class="service-card-front">
              <div class="service-icon-wrap">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                </svg>
              </div>
              <h3>24/7 Call &amp; Text Assistant</h3>
            </div>
            <div class="service-card-back">
              <p>Answers calls after hours, qualifies leads, books appointments, and triages emergencies. Never lose a customer to a missed call again.</p>
              <button class="card-learn-more">Learn More →</button>
            </div>
          </div>
        </a>

        <a href="/customer-automation" class="service-card reveal" data-delay="0.15" data-card-url="/customer-automation">
          <div class="service-card-inner">
            <div class="service-card-front">
              <div class="service-icon-wrap">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                  <circle cx="9" cy="7" r="4"/>
                  <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                  <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
              </div>
              <h3>Employee Scheduling</h3>
            </div>
            <div class="service-card-back">
              <p>Schedule your team and customers in one system. Prevent double-bookings, track availability, and auto-assign jobs. Works with When I Work, Deputy, and Homebase.</p>
              <button class="card-learn-more">Learn More →</button>
            </div>
          </div>
        </a>

        <a href="/operations-automation" class="service-card reveal" data-delay="0.3" data-card-url="/operations-automation">
          <div class="service-card-inner">
            <div class="service-card-front">
              <div class="service-icon-wrap">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="18" cy="5" r="3"/>
                  <circle cx="6" cy="12" r="3"/>
                  <circle cx="18" cy="19" r="3"/>
                  <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
                  <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
                </svg>
              </div>
              <h3>CRM &amp; Workflow Integration</h3>
            </div>
            <div class="service-card-back">
              <p>Connect your CRM, automate follow-ups, sync customer data across platforms. Works with monday.com, Hubspot, Pipedrive, and Salesforce.</p>
              <button class="card-learn-more">Learn More →</button>
            </div>
          </div>
        </a>

        <a href="/lead-automation" class="service-card reveal" data-delay="0.45" data-card-url="/lead-automation">
          <div class="service-card-inner">
            <div class="service-card-front">
              <div class="service-icon-wrap">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/>
                  <circle cx="12" cy="12" r="6"/>
                  <circle cx="12" cy="12" r="2"/>
                </svg>
              </div>
              <h3>Lead Capture</h3>
            </div>
            <div class="service-card-back">
              <p>Capture every call, chat, and form submission. Automated lead qualification, instant notifications, and lead scoring. Never lose a potential customer again.</p>
              <button class="card-learn-more">Learn More →</button>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- HOW WE WORK -->
  <section id="process" data-speed="0.75">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-eyebrow">How It Works</p>
        <h2 class="section-title word-reveal" data-delay="0.05">From Call to Install in 4 Steps</h2>
        <p class="section-subtitle">
          No black boxes, no endless discovery calls. We move efficiently from understanding
          your pain points to launching automation that saves you hours every week.
        </p>
      </div>

      <div class="process-steps" id="process-steps">
        <div class="process-line-wrap" aria-hidden="true">
          <div class="process-line-bg"></div>
          <div class="process-line-fill" id="process-line-fill"></div>
        </div>
        <div class="process-step" data-step="1">
          <div class="step-number-wrap">01</div>
          <h3 class="step-title">Discover</h3>
          <p class="step-desc">We learn where you're losing time and money. No jargon — just listening and honest assessment of what automation can fix.</p>
        </div>
        <div class="process-step" data-step="2">
          <div class="step-number-wrap">02</div>
          <h3 class="step-title">Design</h3>
          <p class="step-desc">We architect an automation system tailored to your workflows, your team size, and your budget.</p>
        </div>
        <div class="process-step" data-step="3">
          <div class="step-number-wrap">03</div>
          <h3 class="step-title">Build &amp; Launch</h3>
          <p class="step-desc">Your AI systems are built, tested, and deployed. You see progress at every step and approve before we go live.</p>
        </div>
        <div class="process-step" data-step="4">
          <div class="step-number-wrap">04</div>
          <h3 class="step-title">Optimize</h3>
          <p class="step-desc">Ongoing monitoring, refinement, and expansion as your business scales. We grow with you and add new automations as needs arise.</p>
        </div>
      </div>

      <div class="process-cta-wrap">
        <a href="/process" class="btn-primary process-cta" id="process-cta">See How It Works</a>
      </div>
    </div>
  </section>

  <!-- CONTACT / CTA -->
  <section id="contact" data-speed="0.75" style="display: none;">
    <div class="container">
      <ContactCard />
    </div>
  </section>

  <!-- BOOKING WIDGET -->
  <section id="booking" data-speed="0.75" style="background: var(--bg-void); padding: 6rem 0;">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-eyebrow">Live Demo</p>
        <h2 class="section-title word-reveal" data-delay="0.05">Book a Call</h2>
        <p class="section-subtitle">
          See our booking automation in action. This widget integrates with Google Calendar, captures your info, and sends you a confirmation — automatically.
        </p>
      </div>
      <div class="reveal" data-delay="0.2">
        <BookingWidget calLink="ice-cap-labs-lnw3hf/30min" title="Schedule Your Discovery Call" />
      </div>
    </div>
  </section>

</BaseLayout>

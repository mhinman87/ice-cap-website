---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCard from '../components/ContactCard.astro';
---
<BaseLayout title="Ice Cap Labs — AI Automation for Service Businesses | Wichita, KS" description="AI automation for HVAC, plumbing, and electrical companies in Wichita. 24/7 AI call assistants that answer phones, qualify leads, and book appointments automatically." footerSpeed="0.75">

  <!-- HERO -->
  <section id="hero">
    <div id="cursor-spotlight" aria-hidden="true"></div>
    <div class="hero-ambient" aria-hidden="true"></div>

    <!-- PARALLAX LAYERS -->
    <div id="parallax-container" aria-hidden="true">
      <div class="parallax-layer layer-6" data-speed="0"></div>
      <div class="parallax-layer layer-5" data-speed="0.05"></div>
      <div class="parallax-layer layer-4" data-speed="0.15"></div>
      <div class="parallax-layer layer-3" data-speed="0.3"></div>
      <div class="parallax-layer layer-2" data-speed="0.5"></div>
      <div class="parallax-layer layer-1" data-speed="0.75"></div>
    </div>

    <div class="hero-content">
      <h1 class="hero-title word-reveal" data-delay="0.15">Work Smarter. Win More.</h1>
      <p class="hero-subtitle">AI systems that answer calls, book jobs, and follow up so you can focus on the work that matters.</p>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" data-speed="0.75">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-eyebrow">How We Help</p>
        <h2 class="section-title word-reveal" data-delay="0.05">Four Ways to Automate Your Business</h2>
        <p class="section-subtitle">
          Every system we build is designed to solve the most expensive problems service businesses
          face: missed calls, lost leads, endless admin work, and manual scheduling.
        </p>
      </div>

      <div class="services-grid">
        <a href="/call-assistant" class="service-card reveal" data-delay="0.0" data-card-url="/call-assistant">
          <div class="service-card-inner">
            <div class="service-card-front">
              <div class="service-icon-wrap">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                </svg>
              </div>
              <h3>24/7 Call &amp; Text Assistant</h3>
            </div>
            <div class="service-card-back">
              <p>Answers calls after hours, qualifies leads, books appointments, and triages emergencies. Never lose a customer to a missed call again.</p>
              <button class="card-learn-more">Learn More →</button>
            </div>
          </div>
        </a>

        <a href="/lead-automation" class="service-card reveal" data-delay="0.15" data-card-url="/lead-automation">
          <div class="service-card-inner">
            <div class="service-card-front">
              <div class="service-icon-wrap">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
                </svg>
              </div>
              <h3>Lead Management &amp; Follow-Up</h3>
            </div>
            <div class="service-card-back">
              <p>Instant responses to web inquiries, automated follow-up sequences, and CRM integration. Turn more leads into paying customers without manual work.</p>
              <button class="card-learn-more">Learn More →</button>
            </div>
          </div>
        </a>

        <a href="/customer-automation" class="service-card reveal" data-delay="0.3" data-card-url="/customer-automation">
          <div class="service-card-inner">
            <div class="service-card-front">
              <div class="service-icon-wrap">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                </svg>
              </div>
              <h3>Customer Service Automation</h3>
            </div>
            <div class="service-card-back">
              <p>Post-service follow-ups, review requests, appointment reminders, and payment notifications. Keep customers happy and coming back automatically.</p>
              <button class="card-learn-more">Learn More →</button>
            </div>
          </div>
        </a>

        <a href="/operations-automation" class="service-card reveal" data-delay="0.45" data-card-url="/operations-automation">
          <div class="service-card-inner">
            <div class="service-card-front">
              <div class="service-icon-wrap">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                  <line x1="16" y1="2" x2="16" y2="6"/>
                  <line x1="8" y1="2" x2="8" y2="6"/>
                  <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
              </div>
              <h3>Operations &amp; Scheduling</h3>
            </div>
            <div class="service-card-back">
              <p>Job scheduling, dispatch automation, inventory alerts, and team coordination. Run your business like a well-oiled machine without the chaos.</p>
              <button class="card-learn-more">Learn More →</button>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- HOW WE WORK -->
  <section id="process" data-speed="0.75">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-eyebrow">How It Works</p>
        <h2 class="section-title word-reveal" data-delay="0.05">From Call to Install in 4 Steps</h2>
        <p class="section-subtitle">
          No black boxes, no endless discovery calls. We move efficiently from understanding
          your pain points to launching automation that saves you hours every week.
        </p>
      </div>

      <div class="process-steps" id="process-steps">
        <div class="process-line-wrap" aria-hidden="true">
          <div class="process-line-bg"></div>
          <div class="process-line-fill" id="process-line-fill"></div>
        </div>
        <div class="process-step" data-step="1">
          <div class="step-number-wrap">01</div>
          <h3 class="step-title">Discover</h3>
          <p class="step-desc">We learn where you're losing time and money. No jargon — just listening and honest assessment of what automation can fix.</p>
        </div>
        <div class="process-step" data-step="2">
          <div class="step-number-wrap">02</div>
          <h3 class="step-title">Design</h3>
          <p class="step-desc">We architect an automation system tailored to your workflows, your team size, and your budget.</p>
        </div>
        <div class="process-step" data-step="3">
          <div class="step-number-wrap">03</div>
          <h3 class="step-title">Build &amp; Launch</h3>
          <p class="step-desc">Your AI systems are built, tested, and deployed. You see progress at every step and approve before we go live.</p>
        </div>
        <div class="process-step" data-step="4">
          <div class="step-number-wrap">04</div>
          <h3 class="step-title">Optimize</h3>
          <p class="step-desc">Ongoing monitoring, refinement, and expansion as your business scales. We grow with you and add new automations as needs arise.</p>
        </div>
      </div>

      <div class="process-cta-wrap">
        <a href="/process" class="btn-primary process-cta" id="process-cta">See How It Works</a>
      </div>
    </div>
  </section>

  <!-- WHY ICE CAP LABS -->
  <section id="why" data-speed="0.75">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-eyebrow">Why Ice Cap Labs</p>
        <h2 class="section-title word-reveal" data-delay="0.05">Built for Service Businesses</h2>
        <p class="section-subtitle">
          Most automation agencies target enterprise clients. Most charge $10k+ for basic chatbots.
          Ice Cap Labs is built for the service businesses that keep Wichita running.
        </p>
      </div>

      <div class="why-grid">
        <div class="why-item reveal" data-delay="0.0">
          <div class="why-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
          </div>
          <div>
            <h3>No Overhead Bloat</h3>
            <p>You get automation that works like a full-time employee without the cost of hiring, benefits, or training.</p>
          </div>
        </div>

        <div class="why-item reveal" data-delay="0.05">
          <div class="why-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
              <line x1="8" y1="21" x2="16" y2="21"/>
              <line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
          </div>
          <div>
            <h3>One Partner, Complete System</h3>
            <p>Call handling, lead follow-up, scheduling, and customer service — all integrated under one roof. No juggling multiple platforms.</p>
          </div>
        </div>

        <div class="why-item reveal" data-delay="0.1">
          <div class="why-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <div>
            <h3>Built for Service Businesses</h3>
            <p>No enterprise pricing. No enterprise complexity. Systems sized and priced for HVAC, plumbing, and electrical companies in Wichita.</p>
          </div>
        </div>

        <div class="why-item reveal" data-delay="0.15">
          <div class="why-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
            </svg>
          </div>
          <div>
            <h3>Proven Results, Not Hype</h3>
            <p>Systems that actually save you 15+ hours per week and capture missed revenue — not experimental demos that look impressive and deliver nothing.</p>
          </div>
        </div>

        <div class="why-item reveal" data-delay="0.2">
          <div class="why-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" y1="8" x2="12" y2="12"/>
              <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
          </div>
          <div>
            <h3>Strategic Thinking</h3>
            <p>We think about your revenue model, not just your current task list. Automation should solve problems that cost you money.</p>
          </div>
        </div>

        <div class="why-item reveal" data-delay="0.25">
          <div class="why-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </div>
          <div>
            <h3>Transparent Process</h3>
            <p>You see everything. No black boxes, no mystery retainers. Clear pricing, honest timelines, and real communication at every stage.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT / CTA -->
  <section id="contact" data-speed="0.75">
    <div class="container">
      <ContactCard />
    </div>
  </section>

</BaseLayout>

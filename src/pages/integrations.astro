---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Integrations | Works With Your Existing Software | Ice Cap Labs" description="Ice Cap Labs workflow automation integrates with monday.com, Hubspot, Pipedrive, Google Calendar, and 500+ other tools you already use.">

  <!-- HERO -->
  <header class="page-header">
    <p class="section-eyebrow reveal">Integrations</p>
    <h1 class="page-title word-reveal">Works With Your Existing Software</h1>
    <p class="page-subtitle reveal" data-delay="0.2">
      Ice Cap Labs workflow automation integrates with the tools you already use. No rip-and-replace. Just seamless connections.
    </p>
  </header>

  <!-- INTEGRATIONS GRID -->
  <section class="integrations-section">
    <div class="container">
      
      <!-- CRM & Customer Management -->
      <div class="integration-category reveal" data-delay="0.1">
        <h2 class="category-title">CRM & Customer Management</h2>
        <div class="integration-grid">
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>monday.com</h3>
            <p>Sync leads, customers, and workflows</p>
          </div>
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>Hubspot CRM</h3>
            <p>Automated lead capture & contact updates</p>
          </div>
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>Pipedrive</h3>
            <p>Sales pipeline automation</p>
          </div>
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>Salesforce</h3>
            <p>Enterprise CRM integration</p>
          </div>
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>Zoho CRM</h3>
            <p>Customer data sync</p>
          </div>
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>Google Sheets</h3>
            <p>Simple spreadsheet tracking</p>
          </div>
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>Airtable</h3>
            <p>Flexible database workflows</p>
          </div>
        </div>
      </div>

      <!-- Scheduling & Calendar -->
      <div class="integration-category reveal" data-delay="0.2">
        <h2 class="category-title">Scheduling & Calendar</h2>
        <div class="integration-grid">
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>Google Calendar</h3>
            <p>Automated appointment booking</p>
          </div>
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>Outlook Calendar</h3>
            <p>Microsoft 365 sync</p>
          </div>
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>Cal.com</h3>
            <p>Open-source scheduling</p>
          </div>
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>Calendly</h3>
            <p>Meeting scheduling automation</p>
          </div>
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>Acuity Scheduling</h3>
            <p>Client booking workflows</p>
          </div>
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>SimplyBook.me</h3>
            <p>Service appointment booking</p>
          </div>
        </div>
      </div>

      <!-- Employee Scheduling -->
      <div class="integration-category reveal" data-delay="0.3">
        <h2 class="category-title">Employee Scheduling</h2>
        <div class="integration-grid">
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>When I Work</h3>
            <p>Employee shift scheduling</p>
          </div>
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>Deputy</h3>
            <p>Team scheduling & time tracking</p>
          </div>
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>Homebase</h3>
            <p>Scheduling & HR workflows</p>
          </div>
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>7shifts</h3>
            <p>Restaurant & retail scheduling</p>
          </div>
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>Humanity</h3>
            <p>Workforce management</p>
          </div>
        </div>
      </div>

      <!-- Communication -->
      <div class="integration-category reveal" data-delay="0.4">
        <h2 class="category-title">Communication</h2>
        <div class="integration-grid">
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>Twilio</h3>
            <p>Voice & SMS automation</p>
          </div>
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>Gmail</h3>
            <p>Email automation & notifications</p>
          </div>
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>Slack</h3>
            <p>Team notifications & alerts</p>
          </div>
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>Microsoft Teams</h3>
            <p>Business communication sync</p>
          </div>
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>WhatsApp Business</h3>
            <p>Customer messaging automation</p>
          </div>
        </div>
      </div>

      <!-- Payments -->
      <div class="integration-category reveal" data-delay="0.5">
        <h2 class="category-title">Payments</h2>
        <div class="integration-grid">
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>Stripe</h3>
            <p>Payment processing & invoicing</p>
          </div>
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>Square</h3>
            <p>Point-of-sale integration</p>
          </div>
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>PayPal</h3>
            <p>Online payment automation</p>
          </div>
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>QuickBooks</h3>
            <p>Accounting & invoicing sync</p>
          </div>
        </div>
      </div>

      <!-- Field Service Management -->
      <div class="integration-category reveal" data-delay="0.6">
        <h2 class="category-title">Field Service Management</h2>
        <div class="integration-grid">
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>Jobber</h3>
            <p>Service business automation</p>
          </div>
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>ServiceTitan</h3>
            <p>HVAC/plumbing/electrical workflows</p>
          </div>
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>Housecall Pro</h3>
            <p>Service industry scheduling</p>
          </div>
          <div class="integration-card">
            <div class="integration-icon">✓</div>
            <h3>FieldEdge</h3>
            <p>Field service dispatch</p>
          </div>
        </div>
      </div>

      <!-- Custom & API -->
      <div class="integration-category reveal" data-delay="0.7">
        <h2 class="category-title">Custom Integrations</h2>
        <div class="integration-grid">
          <div class="integration-card featured">
            <div class="integration-icon">⚡</div>
            <h3>Zapier</h3>
            <p>Connect 5,000+ apps instantly</p>
          </div>
          <div class="integration-card featured">
            <div class="integration-icon">⚡</div>
            <h3>Make (Integromat)</h3>
            <p>Advanced workflow automation</p>
          </div>
          <div class="integration-card featured">
            <div class="integration-icon">⚡</div>
            <h3>Custom API</h3>
            <p>Build your own integrations</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="page-cta reveal">
    <h2>Don't See Your Software?</h2>
    <p>We can integrate with virtually any tool that has an API. If you use it, we can connect it.</p>
    <a href="/contact" class="btn-primary">Ask About Custom Integrations</a>
  </section>

</BaseLayout>

<style>
.integrations-section {
  padding: 4rem 1rem;
  background: var(--bg-deep);
}

.integration-category {
  margin-bottom: 4rem;
}

.category-title {
  font-size: 1.75rem;
  color: var(--text-primary);
  margin-bottom: 1.5rem;
  font-weight: 600;
}

.integration-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
  gap: 1.5rem;
}

.integration-card {
  background: rgba(14, 165, 233, 0.05);
  border: 1px solid rgba(14, 165, 233, 0.2);
  border-radius: 12px;
  padding: 1.5rem;
  transition: all 0.3s ease;
}

.integration-card:hover {
  background: rgba(14, 165, 233, 0.1);
  border-color: var(--accent);
  transform: translateY(-2px);
}

.integration-card.featured {
  background: rgba(14, 165, 233, 0.15);
  border: 2px solid var(--accent);
}

.integration-icon {
  font-size: 1.5rem;
  margin-bottom: 0.75rem;
  color: var(--accent);
}

.integration-card h3 {
  font-size: 1.1rem;
  color: var(--text-primary);
  margin-bottom: 0.5rem;
  font-weight: 600;
}

.integration-card p {
  font-size: 0.9rem;
  color: var(--text-secondary);
  line-height: 1.5;
}

@media (max-width: 768px) {
  .integration-grid {
    grid-template-columns: 1fr;
  }
}
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Lead Capture | Ice Cap Labs" description="A branded landing page that turns website visitors into leads automatically. Every submission saved, every lead followed up — 24/7.">

  <!-- PIXEL HERO -->
  <section class="pixel-hero">
    <h1 class="pixel-hero-title" aria-label="Lead Capture">LEAD CAPTURE</h1>
    <div class="pixel-title-grid" id="pixel-title-grid"></div>
  </section>

  <!-- OUTCOME STATEMENT -->
  <section>
    <div class="container">
      <div class="section-header reveal" style="max-width: 760px; margin-left: auto; margin-right: auto; text-align: center;">
        <p class="section-eyebrow">Lead Capture</p>
        <h2 class="section-title word-reveal" data-delay="0.05">
          Turn your website traffic into a list of real leads — automatically.
        </h2>
        <p class="section-subtitle">
          Built for local service businesses that depend on new customers. Every visitor who fills out your form gets an immediate welcome email. Every lead lands in your dashboard, ready to follow up.
        </p>
      </div>
    </div>
  </section>

  <!-- WHAT YOU GET -->
  <section style="background: var(--bg-void); padding: 5rem 0;">
    <div class="container">
      <div class="section-header reveal" style="margin-bottom: 2.5rem; text-align: center;">
        <p class="section-eyebrow">What You Get</p>
      </div>
      <div class="pricing-card reveal">
        <div class="ai-columns">
          <div class="ai-card">
            <div class="ai-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="3" width="20" height="14" rx="2"/>
                <path d="M8 21h8"/>
                <path d="M12 17v4"/>
                <path d="M2 7h20"/>
              </svg>
            </div>
            <h3 class="ai-heading">Branded Landing Page</h3>
            <p class="ai-copy">A conversion-optimized page built for your business. Your colors, your offer, your brand.</p>
          </div>
          <div class="ai-card">
            <div class="ai-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <h3 class="ai-heading">Automatic Welcome Email</h3>
            <p class="ai-copy">The moment someone submits, they get a personalized email from you. No manual follow-up needed.</p>
          </div>
          <div class="ai-card">
            <div class="ai-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="20" x2="18" y2="10"/>
                <line x1="12" y1="20" x2="12" y2="4"/>
                <line x1="6" y1="20" x2="6" y2="14"/>
              </svg>
            </div>
            <h3 class="ai-heading">Admin Dashboard</h3>
            <p class="ai-copy">Every lead saved, searchable, and exportable. Password-protected. You're in control.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section style="padding: 5rem 0;">
    <div class="container">
      <div class="section-header reveal" style="margin-bottom: 2.5rem; text-align: center;">
        <p class="section-eyebrow">Pricing</p>
      </div>
      <div class="reveal" data-delay="0.1" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; max-width: 560px; margin: 0 auto;">
        <div style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 2rem; text-align: center;">
          <p style="font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent-bright); margin-bottom: 0.75rem;">Setup</p>
          <p style="font-size: 1.5rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.4rem;">$1,500 – $2,500</p>
          <p style="font-size: 0.85rem; color: var(--text-secondary);">One-time</p>
        </div>
        <div style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 2rem; text-align: center;">
          <p style="font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent-bright); margin-bottom: 0.75rem;">Monthly</p>
          <p style="font-size: 1.5rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.4rem;">$199 – $499</p>
          <p style="font-size: 0.85rem; color: var(--text-secondary);">Hosting, support, updates</p>
        </div>
      </div>
      <p class="reveal" data-delay="0.15" style="text-align: center; color: var(--text-secondary); font-size: 0.85rem; margin-top: 1.5rem; max-width: 400px; margin-left: auto; margin-right: auto;">Every build is custom. Final pricing reflects your scope.</p>
    </div>
  </section>

  <!-- DEMO CTA -->
  <section style="background: var(--bg-void); padding: 6rem 0; text-align: center;">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-eyebrow">Live Demo</p>
        <h2 class="section-title word-reveal" data-delay="0.05">See It Live</h2>
        <p class="section-subtitle">Try the real product. No signup required.</p>
      </div>
      <div class="reveal" data-delay="0.2">
        <a href="#" class="btn-primary" data-coming-soon="true">Open Demo →</a>
      </div>
    </div>
  </section>

</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Marketing — Ice Cap Labs" description="Digital marketing and SEO services from Ice Cap Labs — search optimization, paid ads, social media, email campaigns, and analytics.">

  <!-- PIXEL HERO -->
  <section class="pixel-hero">
    <h1 class="pixel-hero-title" aria-label="Marketing">MARKETING</h1>
    <div class="pixel-title-grid" id="pixel-title-grid"></div>
  </section>

  <!-- SERVICE DETAILS -->
  <section class="blocks-section" style="background: var(--bg-deep);">
    <div class="blocks-container">
      <div class="service-block reveal">
        <div class="block-inner">
          <div>
            <p class="block-number">Digital Marketing &amp; SEO</p>
            <h2 class="block-title">Visibility That Compounds</h2>
          </div>
          <div>
            <p class="block-desc">
              Visibility that compounds over time. We build search engine strategies, run targeted campaigns, and automate your social presence so your business gets found by the right people without requiring constant manual effort.
            </p>
            <ul class="block-list">
              <li>Search engine optimization (on-page and technical SEO)</li>
              <li>Content strategy and creation</li>
              <li>Social media management and automation</li>
              <li>Paid advertising (Google Ads, Meta, LinkedIn)</li>
              <li>Email marketing and drip campaigns</li>
              <li>Analytics, reporting, and conversion tracking</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="page-cta reveal">
    <h2>Ready to Grow?</h2>
    <p>Let's talk about getting your business in front of the right people.</p>
    <a href="/contact" class="btn-primary">Get Started</a>
  </section>

</BaseLayout>

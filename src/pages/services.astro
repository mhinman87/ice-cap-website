---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookingWidget from '../components/BookingWidget.astro';
---
<BaseLayout title="Workflow Automation Services | CRM, Scheduling, Lead Capture | Ice Cap Labs" description="Workflow automation for Wichita service businesses. Employee scheduling, CRM automation, lead capture, customer communication. Works with monday.com, Hubspot, Pipedrive, and 50+ tools.">

  <!-- HERO -->
  <header class="page-header">
    <h1 class="page-title word-reveal">Services</h1>
    <p class="page-subtitle reveal" data-delay="0.2">
      We automate the workflows that slow you down: employee scheduling, lead capture, CRM updates, customer communication. Works with <a href="/integrations" style="color: var(--accent); text-decoration: underline;">monday.com, Hubspot, Pipedrive, and 50+ other tools</a> you already use.
    </p>
    <a href="/contact" class="btn-primary reveal" data-delay="0.4">Get Started</a>
  </header>

  <!-- SERVICE COLUMNS -->
  <section class="svc-columns-section">
    <div class="svc-columns" id="svc-columns">

      <div class="svc-col" style="--col-bg:#0a1628">
        <a href="/call-assistant" class="svc-col-title">24/7 Call &amp; Text Assistant</a>
        <ul class="svc-col-list">
          <li>After-hours call answering</li>
          <li>Lead qualification &amp; booking</li>
          <li>Calendar sync (Google, Cal.com)</li>
          <li>SMS &amp; voicemail response</li>
          <li>Emergency triage</li>
          <li>Works with: Twilio, ElevenLabs</li>
        </ul>
      </div>

      <div class="svc-col" style="--col-bg:#0c2d4a">
        <a href="/customer-automation" class="svc-col-title">Employee Scheduling</a>
        <ul class="svc-col-list">
          <li>Employee + customer scheduling in one system</li>
          <li>Prevent double-bookings</li>
          <li>Team availability tracking</li>
          <li>Auto-assign jobs to available staff</li>
          <li>Shift scheduling integration</li>
          <li>Works with: When I Work, Deputy, Homebase</li>
        </ul>
      </div>

      <div class="svc-col" style="--col-bg:#0e4d6e">
        <a href="/operations-automation" class="svc-col-title">CRM &amp; Workflow Integration</a>
        <ul class="svc-col-list">
          <li>Automated lead capture to CRM</li>
          <li>Customer communication workflows</li>
          <li>Follow-up automation (email, SMS)</li>
          <li>Data sync across platforms</li>
          <li>Works with: monday.com, Hubspot, Pipedrive</li>
        </ul>
      </div>

      <div class="svc-col" style="--col-bg:#0ea5e9">
        <a href="/lead-automation" class="svc-col-title">Lead Capture</a>
        <ul class="svc-col-list">
          <li>Capture every call, chat, form submission</li>
          <li>Automated lead qualification</li>
          <li>Instant notifications (email, SMS, Slack)</li>
          <li>Lead scoring &amp; routing</li>
          <li>Works with your existing CRM</li>
        </ul>
      </div>

    </div>
  </section>

  <!-- BOOKING WIDGET -->
  <section id="contact" style="background: var(--bg-void); padding: 6rem 0;">
    <div class="container">
      <div class="section-header reveal" style="margin-bottom: 3rem;">
        <p class="section-eyebrow">Ready to Start?</p>
        <h2 class="section-title word-reveal">Book a Call</h2>
      </div>
      <BookingWidget title="Schedule Your Discovery Call" />
    </div>
  </section>

</BaseLayout>

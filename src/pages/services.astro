---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookingWidget from '../components/BookingWidget.astro';
---
<BaseLayout title="AI Integration Services for Small Businesses | Ice Cap Labs" description="Practical AI integration for small businesses. Lead capture, scheduling, CRM workflows, customer communication, and custom automation that saves time and reduces admin.">

  <!-- HERO -->
  <header class="page-header">
    <h1 class="page-title word-reveal">AI Integration Services</h1>
    <p class="page-subtitle reveal" data-delay="0.2">
      We help small businesses implement practical AI systems for lead capture, scheduling, CRM workflows, customer communication, and custom internal automation. We work with <a href="/integrations" style="color: var(--accent); text-decoration: underline;">monday.com, Hubspot, Pipedrive, and 50+ other tools</a> you already use.
    </p>
    <a href="/contact" class="btn-primary reveal" data-delay="0.4">Get Started</a>
  </header>

  <!-- SERVICE COLUMNS -->
  <section class="svc-columns-section">
    <div class="svc-columns" id="svc-columns">

      <div class="svc-col" style="--col-bg:#0a1628">
        <a href="/call-assistant" class="svc-col-title">Lead Capture &amp; Customer Communication</a>
        <ul class="svc-col-list">
          <li>Capture more inbound leads</li>
          <li>Improve response flows and handoffs</li>
          <li>Automate customer follow-up</li>
          <li>Reduce missed opportunities after hours</li>
          <li>Works with phone, forms, chat, and email</li>
          <li>Works with: Twilio, ElevenLabs</li>
        </ul>
      </div>

      <div class="svc-col" style="--col-bg:#0c2d4a">
        <a href="/customer-automation" class="svc-col-title">Scheduling &amp; Booking Workflows</a>
        <ul class="svc-col-list">
          <li>Customer booking flows that are easier to use</li>
          <li>Prevent double-bookings</li>
          <li>Team availability tracking</li>
          <li>Auto-assign jobs to available staff</li>
          <li>Internal scheduling coordination</li>
          <li>Works with: When I Work, Deputy, Homebase</li>
        </ul>
      </div>

      <div class="svc-col" style="--col-bg:#0e4d6e">
        <a href="/operations-automation" class="svc-col-title">CRM &amp; Internal Workflow Automation</a>
        <ul class="svc-col-list">
          <li>Automated lead capture to CRM</li>
          <li>Customer communication workflows</li>
          <li>Follow-up automation (email, SMS)</li>
          <li>Data sync across platforms</li>
          <li>Admin tasks that happen without manual copy-and-paste</li>
          <li>Works with: monday.com, Hubspot, Pipedrive</li>
        </ul>
      </div>

      <div class="svc-col" style="--col-bg:#0ea5e9">
        <a href="/lead-automation" class="svc-col-title">Custom AI Integration</a>
        <ul class="svc-col-list">
          <li>Custom systems built around your workflow</li>
          <li>Automated lead qualification</li>
          <li>Instant notifications (email, SMS, Slack)</li>
          <li>AI-assisted routing and business logic</li>
          <li>Built around the tools your team already uses</li>
        </ul>
      </div>

    </div>
  </section>

  <!-- BOOKING WIDGET -->
  <section id="contact" style="background: var(--bg-void); padding: 6rem 0;">
    <div class="container">
      <div class="section-header reveal" style="margin-bottom: 3rem;">
        <p class="section-eyebrow">Ready to Start?</p>
        <h2 class="section-title word-reveal">Book a Call</h2>
      </div>
      <BookingWidget title="Schedule Your Discovery Call" />
    </div>
  </section>

</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCard from '../components/ContactCard.astro';
---
<BaseLayout title="Services | Ice Cap Labs | AI Automation | Wichita, KS" description="AI automation services for service businesses in Wichita, Kansas. 24/7 call handling, lead management, customer service, and operations automation.">

  <!-- HERO -->
  <header class="page-header">
    <h1 class="page-title word-reveal">Services</h1>
    <p class="page-subtitle reveal" data-delay="0.2">
      AI automation systems built for service businesses that don't have time for admin work. From 24/7 call handling to customer follow-ups, we automate the repetitive 60% so you can focus on the work that matters.
    </p>
    <a href="/contact" class="btn-primary reveal" data-delay="0.4">Get Started</a>
  </header>

  <!-- SERVICE COLUMNS -->
  <section class="svc-columns-section">
    <div class="svc-columns" id="svc-columns">

      <div class="svc-col" style="--col-bg:#0a1628">
        <a href="/call-assistant" class="svc-col-title">24/7 Call &amp; Text Assistant</a>
        <ul class="svc-col-list">
          <li>After-hours call answering</li>
          <li>Lead qualification</li>
          <li>Appointment booking</li>
          <li>Emergency triage</li>
          <li>SMS &amp; voicemail response</li>
          <li>Calendar integration</li>
        </ul>
      </div>

      <div class="svc-col" style="--col-bg:#0c2d4a">
        <a href="/lead-automation" class="svc-col-title">Lead Management &amp; Follow-Up</a>
        <ul class="svc-col-list">
          <li>Instant web inquiry responses</li>
          <li>Automated follow-up sequences</li>
          <li>CRM integration &amp; updates</li>
          <li>Lead scoring &amp; qualification</li>
          <li>Missed call recovery</li>
          <li>Pipeline automation</li>
        </ul>
      </div>

      <div class="svc-col" style="--col-bg:#0e4d6e">
        <a href="/customer-automation" class="svc-col-title">Customer Service Automation</a>
        <ul class="svc-col-list">
          <li>Post-service follow-ups</li>
          <li>Review request automation</li>
          <li>Appointment reminders</li>
          <li>Payment notifications</li>
          <li>Customer satisfaction surveys</li>
          <li>Loyalty &amp; retention campaigns</li>
        </ul>
      </div>

      <div class="svc-col" style="--col-bg:#0ea5e9">
        <a href="/operations-automation" class="svc-col-title">Operations &amp; Scheduling</a>
        <ul class="svc-col-list">
          <li>Job scheduling automation</li>
          <li>Dispatch &amp; routing</li>
          <li>Inventory alerts</li>
          <li>Team coordination</li>
          <li>Time tracking integration</li>
          <li>Workflow automation</li>
        </ul>
      </div>

    </div>
  </section>

  <!-- CONTACT / CTA -->
  <section id="contact">
    <div class="container">
      <ContactCard eyebrow="Ready to Start?" />
    </div>
  </section>

</BaseLayout>

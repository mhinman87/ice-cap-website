---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Social Media Automation | Ice Cap Labs" description="AI-generated social media content, scheduled and posted for you — with your approval.">

  <!-- PIXEL HERO -->
  <section class="pixel-hero">
    <h1 class="pixel-hero-title" aria-label="Social Media">SOCIAL MEDIA</h1>
    <div class="pixel-title-grid" id="pixel-title-grid"></div>
  </section>

  <!-- COMING SOON -->
  <section style="padding: 6rem 0; text-align: center;">
    <div class="container">
      <div class="reveal" style="max-width: 600px; margin: 0 auto;">
        <span style="display: inline-block; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent-bright); background: rgba(56,189,248,0.08); border: 1px solid rgba(56,189,248,0.2); border-radius: 100px; padding: 0.35rem 1rem; margin-bottom: 2.5rem;">Coming Soon</span>
        <p class="section-subtitle" style="font-size: 1.1rem; line-height: 1.8;">
          AI-written posts tailored to your business, scheduled across Facebook and Instagram, and sent to you for a quick approval before anything goes live. Stay active online without spending hours on content.
        </p>
        <div style="margin-top: 3rem;">
          <a href="/contact" class="btn-primary">Get Notified When It Launches →</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
